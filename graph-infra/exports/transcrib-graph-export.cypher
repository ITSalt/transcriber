UNWIND [{_id:272, properties:{actor:"User", form_ref:"FORM-MeetingCatalog", description:"AUTHOR opens the meeting catalog page.", id:"UC-001-AS01", updated:datetime('2026-05-18T07:04:19.567Z'), order:1}}, {_id:273, properties:{actor:"System", description:"System loads Meetings owned by the current AUTHOR, sorted by updated_at descending.", id:"UC-001-AS02", updated:datetime('2026-05-18T07:04:19.567Z'), order:2}}, {_id:274, properties:{actor:"System", form_ref:"FORM-MeetingCatalog", description:"System renders one row per Meeting with title (or filename fallback), status badge, language, uploaded_at, and duration_sec from Recording.", id:"UC-001-AS03", updated:datetime('2026-05-18T07:04:19.567Z'), order:3}}, {_id:275, properties:{actor:"System", form_ref:"FORM-MeetingCatalog", description:"For rows in transient states (UPLOADING, TRANSCRIBING, PROTOCOL_GENERATING), System auto-refreshes the row status periodically.", id:"UC-001-AS04", updated:datetime('2026-05-18T07:04:19.567Z'), order:4}}, {_id:276, properties:{actor:"User", form_ref:"FORM-MeetingDetail", description:"AUTHOR navigates to a specific meeting (from catalog or direct link).", id:"UC-002-AS01", updated:datetime('2026-05-18T07:04:19.567Z'), order:1}}, {_id:277, properties:{actor:"System", description:"System loads Meeting + Recording + most recent TranscriptionJob + most recent ProtocolGenerationJob + existence flags for Transcript and Protocol.", id:"UC-002-AS02", updated:datetime('2026-05-18T07:04:19.567Z'), order:2}}, {_id:278, properties:{actor:"System", form_ref:"FORM-MeetingDetail", description:"System renders the detail panel: title, language, status badge, recording metadata, and current job error_reason when Meeting.status=FAILED.", id:"UC-002-AS03", updated:datetime('2026-05-18T07:04:19.567Z'), order:3}}, {_id:279, properties:{actor:"System", form_ref:"FORM-MeetingDetail", description:"System renders conditional action links: View transcript (status >= TRANSCRIPT_READY), Review/Edit protocol (status >= PROTOCOL_READY), Export PDF (status in {PROTOCOL_READY, EDITED}), Delete meeting (always).", id:"UC-002-AS04", updated:datetime('2026-05-18T07:04:19.567Z'), order:4}}, {_id:280, properties:{actor:"User", description:"AUTHOR clicks Delete on the meeting detail page (UC-002).", id:"UC-003-AS01", updated:datetime('2026-05-18T07:04:19.567Z'), order:1}}, {_id:281, properties:{actor:"System", form_ref:"FORM-MeetingDeleteConfirm", description:"System shows confirmation dialog showing the meeting title. If any job is IN_PROGRESS, the dialog warns that the in-flight job will be marked FAILED.", id:"UC-003-AS02", updated:datetime('2026-05-18T07:04:19.567Z'), order:2}}, {_id:282, properties:{actor:"User", form_ref:"FORM-MeetingDeleteConfirm", description:"AUTHOR confirms deletion (or cancels, returning to UC-002 with no changes).", id:"UC-003-AS03", updated:datetime('2026-05-18T07:04:19.567Z'), order:3}}, {_id:283, properties:{actor:"System", description:"System cascade-deletes: any in-flight jobs marked FAILED (error_reason='deleted by user'), Protocol, ProtocolGenerationJob, Transcript, TranscriptionJob, Recording (with storage object removed from EXT-04), Meeting.", id:"UC-003-AS04", updated:datetime('2026-05-18T07:04:19.567Z'), order:4}}, {_id:284, properties:{actor:"System", description:"System redirects to the meeting catalog (UC-001) and shows a success toast.", id:"UC-003-AS05", updated:datetime('2026-05-18T07:04:19.567Z'), order:5}}, {_id:316, properties:{actor:"User", form_ref:"FORM-MeetingUpload", description:"AUTHOR navigates to the Upload page.", id:"UC-100-AS01", updated:datetime('2026-05-18T07:06:29.618Z'), order:1}}, {_id:317, properties:{actor:"User", form_ref:"FORM-MeetingUpload", description:"AUTHOR selects a video file via the file picker and optionally sets language (RU/EN; blank = auto-detect) and title (defaults to filename).", id:"UC-100-AS02", updated:datetime('2026-05-18T07:06:29.618Z'), order:2}}, {_id:318, properties:{actor:"User", form_ref:"FORM-MeetingUpload", description:"AUTHOR clicks the Upload button.", id:"UC-100-AS03", updated:datetime('2026-05-18T07:06:29.618Z'), order:3}}, {_id:319, properties:{actor:"System", description:"System validates: size_bytes <= 500 MB (BRQ-001), mime_type in {video/mp4, video/x-matroska, video/quicktime} (BRQ-002), container integrity (BRQ-003). Decision step.", id:"UC-100-AS04", updated:datetime('2026-05-18T07:06:29.618Z'), order:4}}, {_id:320, properties:{actor:"System", form_ref:"FORM-MeetingUpload", description:"ALT: If validation fails, System shows a human-readable error inline on FORM-MeetingUpload and returns control to AS02. No Meeting / Recording / storage object is created.", id:"UC-100-AS05", updated:datetime('2026-05-18T07:06:29.618Z'), order:5}}, {_id:321, properties:{actor:"System", description:"System creates Meeting (status=UPLOADING) and Recording (filename, size_bytes, mime_type, uploaded_at; storage_path allocated) records in a single transaction.", id:"UC-100-AS06", updated:datetime('2026-05-18T07:06:29.618Z'), order:6}}, {_id:322, properties:{actor:"System", form_ref:"FORM-MeetingUpload", description:"System streams the file in chunks to EXT-04 Object Storage at the allocated storage_path. Progress is reported back to the client.", id:"UC-100-AS07", updated:datetime('2026-05-18T07:06:29.618Z'), order:7}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:ActivityStep;
UNWIND [{_id:323, properties:{actor:"System", description:"On upload completion, System creates TranscriptionJob (status=QUEUED, recording_id, meeting_id) and transitions Meeting.status UPLOADING -> TRANSCRIBING.", id:"UC-100-AS08", updated:datetime('2026-05-18T07:06:29.618Z'), order:8}}, {_id:324, properties:{actor:"System", description:"System redirects AUTHOR to the meeting detail page (UC-002) with a success toast.", id:"UC-100-AS09", updated:datetime('2026-05-18T07:06:29.618Z'), order:9}}, {_id:338, properties:{actor:"System", description:"Worker dequeues a QUEUED TranscriptionJob; sets status=IN_PROGRESS and started_at=now.", id:"UC-200-AS01", updated:datetime('2026-05-18T07:07:36.989Z'), order:1}}, {_id:339, properties:{actor:"System", description:"Worker fetches the Recording file from EXT-04 Object Storage using storage_path.", id:"UC-200-AS02", updated:datetime('2026-05-18T07:07:36.989Z'), order:2}}, {_id:340, properties:{actor:"System", description:"Worker extracts the audio stream from the video container and populates Recording.duration_sec.", id:"UC-200-AS03", updated:datetime('2026-05-18T07:07:36.989Z'), order:3}}, {_id:341, properties:{actor:"System", description:"Worker submits the extracted audio + Meeting.language hint to EXT-02 ASR/Diarization Engine.", id:"UC-200-AS04", updated:datetime('2026-05-18T07:07:36.989Z'), order:4}}, {_id:342, properties:{actor:"System", description:"Worker awaits ASR response. Decision: success vs failure.", id:"UC-200-AS05", updated:datetime('2026-05-18T07:07:36.989Z'), order:5}}, {_id:343, properties:{actor:"System", description:"On success: Worker receives speaker-attributed transcript segments with per-segment timestamps and speaker labels (Speaker 1, Speaker 2, ...).", id:"UC-200-AS06", updated:datetime('2026-05-18T07:07:36.989Z'), order:6}}, {_id:344, properties:{actor:"System", description:"Worker resolves anonymous speaker labels to real names from dialogue context per BRQ-021; populates speaker_map. Unresolved labels remain Speaker N.", id:"UC-200-AS07", updated:datetime('2026-05-18T07:07:36.989Z'), order:7}}, {_id:345, properties:{actor:"System", description:"Worker assembles and persists Transcript (full_text with speakers+timestamps, segments_count, speakers_count, language per BRQ-005 detection if Meeting.language was null, speaker_map, created_at). Transitions Meeting.status -> TRANSCRIPT_READY. Transitions job.status -> COMPLETED with completed_at.", id:"UC-200-AS08", updated:datetime('2026-05-18T07:07:36.989Z'), order:8}}, {_id:346, properties:{actor:"System", description:"Worker auto-creates a ProtocolGenerationJob (status=QUEUED, transcript_id, meeting_id, prompt_template_version) per BRQ-007.", id:"UC-200-AS09", updated:datetime('2026-05-18T07:07:36.989Z'), order:9}}, {_id:347, properties:{actor:"System", description:"ALT (failure path): Worker sets job.status=FAILED with non-null error_reason per BRQ-010 and transitions Meeting.status -> FAILED. Terminal states immutable per BRQ-009.", id:"UC-200-AS10", updated:datetime('2026-05-18T07:07:36.989Z'), order:10}}, {_id:348, properties:{actor:"User", form_ref:"FORM-TranscriptView", description:"AUTHOR clicks 'View transcript' from the meeting detail page (UC-002).", id:"UC-201-AS01", updated:datetime('2026-05-18T07:07:36.989Z'), order:1}}, {_id:349, properties:{actor:"System", description:"System loads the Transcript for the meeting and the speaker_map.", id:"UC-201-AS02", updated:datetime('2026-05-18T07:07:36.989Z'), order:2}}, {_id:350, properties:{actor:"System", form_ref:"FORM-TranscriptView", description:"System renders the transcript with segments, speaker labels (resolved name from speaker_map or 'Speaker N' if unresolved), and timestamps. Header shows segments_count, speakers_count, language, created_at.", id:"UC-201-AS03", updated:datetime('2026-05-18T07:07:36.989Z'), order:3}}, {_id:351, properties:{actor:"User", form_ref:"FORM-TranscriptView", description:"AUTHOR clicks Download.", id:"UC-201-AS04", updated:datetime('2026-05-18T07:07:36.989Z'), order:4}}, {_id:352, properties:{actor:"System", description:"System streams a plain-text file containing the verbatim transcript with speaker labels and timestamps. Filename: '<title>-transcript.txt'.", id:"UC-201-AS05", updated:datetime('2026-05-18T07:07:36.989Z'), order:5}}, {_id:370, properties:{actor:"System", description:"Worker dequeues a QUEUED ProtocolGenerationJob (auto-created by UC-200 AS09); sets status=IN_PROGRESS and started_at=now.", id:"UC-300-AS01", updated:datetime('2026-05-18T07:09:16.868Z'), order:1}}, {_id:371, properties:{actor:"System", description:"Worker loads Transcript via transcript_id and reads its language.", id:"UC-300-AS02", updated:datetime('2026-05-18T07:09:16.868Z'), order:2}}, {_id:372, properties:{actor:"System", description:"Worker selects the LLM prompt template by Transcript.language per BRQ-013 and records the prompt_template_version on the job.", id:"UC-300-AS03", updated:datetime('2026-05-18T07:09:16.868Z'), order:3}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:ActivityStep;
UNWIND [{_id:373, properties:{actor:"System", description:"Worker submits transcript + selected prompt to EXT-03 LLM Protocol Generator.", id:"UC-300-AS04", updated:datetime('2026-05-18T07:09:16.868Z'), order:4}}, {_id:374, properties:{actor:"System", description:"Worker awaits LLM response. Decision: valid response vs failure.", id:"UC-300-AS05", updated:datetime('2026-05-18T07:09:16.868Z'), order:5}}, {_id:375, properties:{actor:"System", description:"Worker parses the LLM response into a structured protocol draft (Markdown with four required sections).", id:"UC-300-AS06", updated:datetime('2026-05-18T07:09:16.868Z'), order:6}}, {_id:376, properties:{actor:"System", description:"Worker validates that all four required sections are present (BRQ-011: Participants, Discussion Topics, Decisions, Action Items). Decision.", id:"UC-300-AS07", updated:datetime('2026-05-18T07:09:16.868Z'), order:7}}, {_id:377, properties:{actor:"System", description:"On success: Worker persists Protocol (markdown_content, version=1, edit_count=0, generated_at=now). Transitions Meeting.status -> PROTOCOL_READY. Transitions job.status -> COMPLETED with completed_at.", id:"UC-300-AS08", updated:datetime('2026-05-18T07:09:16.868Z'), order:8}}, {_id:378, properties:{actor:"System", description:"ALT (failure path): On LLM error, invalid response, or missing required sections, Worker sets job.status=FAILED with non-null error_reason per BRQ-010 and transitions Meeting.status -> FAILED. Terminal states immutable per BRQ-009.", id:"UC-300-AS09", updated:datetime('2026-05-18T07:09:16.868Z'), order:9}}, {_id:379, properties:{actor:"User", form_ref:"FORM-ProtocolEditor", description:"AUTHOR clicks 'Review/Edit protocol' from the meeting detail page (UC-002).", id:"UC-301-AS01", updated:datetime('2026-05-18T07:09:16.868Z'), order:1}}, {_id:380, properties:{actor:"System", description:"System loads Protocol by meeting_id with current markdown_content, version, edit_count, last_edited_at.", id:"UC-301-AS02", updated:datetime('2026-05-18T07:09:16.868Z'), order:2}}, {_id:381, properties:{actor:"System", form_ref:"FORM-ProtocolEditor", description:"System renders a Markdown editor with side-by-side rendered preview. Header shows version and edit_count.", id:"UC-301-AS03", updated:datetime('2026-05-18T07:09:16.868Z'), order:3}}, {_id:382, properties:{actor:"User", form_ref:"FORM-ProtocolEditor", description:"AUTHOR edits Markdown content (canonical form per BRQ-018).", id:"UC-301-AS04", updated:datetime('2026-05-18T07:09:16.868Z'), order:4}}, {_id:383, properties:{actor:"User", form_ref:"FORM-ProtocolEditor", description:"AUTHOR clicks Save.", id:"UC-301-AS05", updated:datetime('2026-05-18T07:09:16.868Z'), order:5}}, {_id:384, properties:{actor:"System", description:"System persists updated markdown_content; increments version by 1 (BRQ-014); increments edit_count by 1 (BRQ-015); sets last_edited_at=now; transitions Meeting.status -> EDITED if not already EDITED (BRQ-008).", id:"UC-301-AS06", updated:datetime('2026-05-18T07:09:16.868Z'), order:6}}, {_id:385, properties:{actor:"System", form_ref:"FORM-ProtocolEditor", description:"System shows a save-confirmation indicator with the new version number.", id:"UC-301-AS07", updated:datetime('2026-05-18T07:09:16.868Z'), order:7}}, {_id:386, properties:{actor:"User", form_ref:"FORM-ProtocolEditor", description:"ALT: If AUTHOR navigates away with unsaved changes, System shows an unsaved-changes warning before navigation.", id:"UC-301-AS08", updated:datetime('2026-05-18T07:09:16.868Z'), order:8}}, {_id:387, properties:{actor:"User", description:"AUTHOR clicks 'Export PDF' button on FORM-MeetingDetail (UC-002) or FORM-ProtocolEditor (UC-301).", id:"UC-302-AS01", updated:datetime('2026-05-18T07:09:16.868Z'), order:1}}, {_id:388, properties:{actor:"System", description:"System loads Protocol.markdown_content (canonical Markdown per BRQ-018).", id:"UC-302-AS02", updated:datetime('2026-05-18T07:09:16.868Z'), order:2}}, {_id:389, properties:{actor:"System", description:"System renders the Markdown to PDF via the export pipeline; the PDF is NOT persisted per BRQ-017.", id:"UC-302-AS03", updated:datetime('2026-05-18T07:09:16.868Z'), order:3}}, {_id:390, properties:{actor:"System", description:"System delivers the PDF as a download. Filename pattern: '<meeting-title>-protocol-v<version>.pdf'.", id:"UC-302-AS04", updated:datetime('2026-05-18T07:09:16.868Z'), order:4}}, {_id:391, properties:{actor:"System", description:"ALT: On render failure, System shows an error toast and no file is delivered. No state change is persisted.", id:"UC-302-AS05", updated:datetime('2026-05-18T07:09:16.868Z'), order:5}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:ActivityStep;
UNWIND [{_id:429, properties:{ba_role_coverage_pct:100.0, notes:"All 9 UCs fully detailed (100% detail). All 6 BA entities realized. All 21 BA rules implemented via 28 AUTOMATES_AS edges. 9 NFRs linked to modules and UCs. SA specification approved for development handoff.", stat_requirements_nfr:9, stat_components:11, stat_automates_as_edges:28, stat_domain_entities:6, next_phase:"nacl-tl-plan", layer:"SA", stat_requirements_functional:33, stat_use_cases:9, tl_handoff_ready:true, project_id:"transcrib", stat_forms:6, overall_readiness_pct:100.0, uc_readiness_pct:100.0, id:"FR-SA-001", stat_use_cases_detailed:9, ba_step_coverage_pct:100.0, stat_modules:4, stat_form_fields:45, created:datetime('2026-05-18T00:00:00Z'), ba_entity_coverage_pct:100.0, module_readiness_json:"[{\"id\":\"mod-common\",\"name\":\"Common / Shell\",\"ucs\":3,\"detailed\":3,\"entities\":1,\"readiness\":100},{\"id\":\"mod-ingest\",\"name\":\"Video Ingest\",\"ucs\":1,\"detailed\":1,\"entities\":1,\"readiness\":100},{\"id\":\"mod-transcription\",\"name\":\"Transcription\",\"ucs\":2,\"detailed\":2,\"entities\":2,\"readiness\":100},{\"id\":\"mod-protocol\",\"name\":\"Protocol Lifecycle\",\"ucs\":3,\"detailed\":3,\"entities\":2,\"readiness\":100}]", validation_summary:"0 critical, 0 warning, 4 info — PASSED", entity_readiness_pct:100.0, ba_rule_coverage_pct:100.0, adrs_created:"ADR-001..ADR-011 (tech stack: Fastify+TS, Postgres+Prisma, BullMQ+Redis, MinIO, TUS, Deepgram, kie.ai, Vite+React, Milkdown+Puppeteer, SSE, pnpm monorepo+Compose)", open_questions_remaining:"none", validation_report_ref:"VR-SA-003", stat_system_roles:2, updated:datetime('2026-05-18T00:00:00Z'), stat_domain_attributes:44, status:"approved"}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:FinalizationReport;
UNWIND [{id:"NFR-001", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"Upload pipeline MUST accept files up to 500 MB via chunked transfer without timeout.", priority:"high", type:"nfr", category:"performance", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Derived from BRQ-001 (file size limit) and SystemContext constraint on handling 300-500 MB files.", status:"draft"}}, {id:"NFR-002", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"Transcription and protocol generation MUST run asynchronously (job-based); UI MUST surface job progress without blocking.", priority:"high", type:"nfr", category:"performance", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Large file processing and external ASR/LLM latency make synchronous execution infeasible (SystemContext).", status:"draft"}}, {id:"NFR-003", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"No processing-time SLA at MVP - best-effort delivery; long-running jobs are acceptable.", type:"nfr", priority:"medium", category:"performance", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Explicit non-SLA per BRQ-019; recorded so future readers do not infer a performance budget.", status:"draft"}}, {id:"NFR-004", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"System MUST support Russian and English throughout (UI, ASR language hint, LLM prompts, error messages).", priority:"high", type:"nfr", category:"integration", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Derived from BRQ-004 and SystemContext language constraint.", status:"draft"}}, {id:"NFR-005", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"Recordings MUST persist in durable object storage (EXT-04) until both Transcript and Protocol artifacts are produced.", priority:"high", type:"nfr", category:"infrastructure", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Derived from BRQ-020 retention rule; necessary for async pipeline durability.", status:"draft"}}, {id:"NFR-006", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"Protocol canonical format is Markdown; PDF export is transient (re-rendered on demand, not persisted).", priority:"high", type:"nfr", category:"integration", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Derived from BRQ-017 (PDF transient) and BRQ-018 (Markdown canonical).", status:"draft"}}, {id:"NFR-007", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"MVP runs without authentication or multi-tenancy; all artifacts treated as owned by the uploader within a single trust boundary.", type:"nfr", priority:"medium", category:"security", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Per SystemContext out-of-scope and single active role (ROL-01 Author).", status:"draft"}}, {id:"NFR-008", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"Job failures MUST be surfaced to the user with a human-readable error_reason; jobs in terminal states (succeeded/failed) are immutable.", priority:"high", type:"nfr", category:"infrastructure", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Derived from BRQ-009 (immutable terminal states) and BRQ-010 (failure recorded with reason).", status:"draft"}}, {id:"NFR-009", properties:{created:datetime('2026-05-18T06:39:52.733Z'), description:"ASSUMPTION: One concurrent user session at MVP - one video processed at a time per user; multi-user/parallel-job scaling design deferred.", type:"assumption", priority:"medium", category:"performance", updated:datetime('2026-05-18T06:39:52.733Z'), rationale:"Per SystemContext assumption 'One video at a time per user session; queue/parallelism design TBD'. Revisit when multi-user scope is added.", status:"needs_review"}}, {id:"RQ-001", properties:{rq_type:"behavioral", description:"Meeting catalog MUST sort meetings by updated_at descending.", source:"behavior", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-002", properties:{rq_type:"behavioral", description:"Meeting rows in transient statuses (UPLOADING, TRANSCRIBING, PROTOCOL_GENERATING) MUST auto-refresh their status without requiring a full page reload.", source:"behavior", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-003", properties:{rq_type:"behavioral", description:"AUTHOR sees only own meetings (ownership scope per BRQ-016). Enforcement is deferred until auth is added (NFR-007); at MVP semantically equivalent to 'all'.", source:"BRQ-016", type:"functional", priority:"medium", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-004", properties:{rq_type:"behavioral", description:"Meeting detail MUST surface the current job's error_reason when Meeting.status=FAILED.", source:"BRQ-010", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-005", properties:{rq_type:"behavioral", description:"Meeting detail action links MUST be gated by Meeting.status: 'View transcript' enabled when status in {TRANSCRIPT_READY, PROTOCOL_GENERATING, PROTOCOL_READY, EDITED}; 'Review/Edit protocol' enabled when status in {PROTOCOL_READY, EDITED}; 'Export PDF' enabled when status in {PROTOCOL_READY, EDITED}.", source:"behavior", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-006", properties:{rq_type:"behavioral", description:"Meeting deletion MUST cascade-remove all derived artifacts: Protocol, ProtocolGenerationJob, Transcript, TranscriptionJob, Recording (including its storage object in EXT-04), and the Meeting itself.", source:"behavior", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-007", properties:{rq_type:"behavioral", description:"Deletion attempted while a job is IN_PROGRESS MUST require explicit user confirmation and MUST mark the in-flight job as FAILED with error_reason='deleted by user'. Terminal-state immutability (BRQ-009) is preserved for already-completed jobs.", source:"BRQ-009", type:"functional", priority:"high", updated:datetime('2026-05-18T07:05:09.22Z'), status:"draft"}}, {id:"RQ-008", properties:{rq_type:"validation", description:"File size validation MUST reject files where size_bytes > 524,288,000 bytes (500 MB) BEFORE any storage upload begins.", source:"BRQ-001", type:"functional", priority:"high", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}, {id:"RQ-009", properties:{rq_type:"validation", description:"MIME validation MUST accept exactly {video/mp4, video/x-matroska, video/quicktime} and reject all other types with a clear user-facing error message.", source:"BRQ-002", type:"functional", priority:"high", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}, {id:"RQ-010", properties:{rq_type:"validation", description:"Container integrity MUST be verified during upload acceptance (probe of header/short-duration sample - exact method TBD per BRQ-003 assumption). Corrupt files are rejected with an error before the Recording is persisted.", source:"BRQ-003", type:"functional", priority:"high", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}, {id:"RQ-011", properties:{rq_type:"behavioral", description:"On successful upload completion, System MUST atomically: (1) finalize Recording metadata, (2) transition Meeting.status from UPLOADING to TRANSCRIBING (BRQ-008 mirror), (3) create exactly one TranscriptionJob with status=QUEUED per Recording (BRQ-006).", source:"BRQ-006, BRQ-008", type:"functional", priority:"high", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}] AS row
CREATE (n:Requirement{id: row.id}) SET n += row.properties;
UNWIND [{id:"RQ-012", properties:{rq_type:"behavioral", description:"Language selector accepts RU, EN, or blank. Blank means Meeting.language stays null and ASR auto-detects the language per BRQ-005; the detected value is recorded as Transcript.language.", source:"BRQ-005", type:"functional", priority:"high", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}, {id:"RQ-013", properties:{rq_type:"behavioral", description:"Meeting.title field defaults to Recording.filename (without extension) when the AUTHOR leaves the title field blank.", source:"behavior", type:"functional", priority:"medium", updated:datetime('2026-05-18T07:06:55.519Z'), status:"draft"}}, {id:"RQ-014", properties:{rq_type:"behavioral", description:"TranscriptionJob lifecycle MUST follow: QUEUED -> IN_PROGRESS -> {COMPLETED, FAILED}. Terminal states {COMPLETED, FAILED} are immutable per BRQ-009.", source:"BRQ-009", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-015", properties:{rq_type:"behavioral", description:"On any failure during transcription (storage fetch, audio extraction, ASR call, response parsing), job.status MUST become FAILED with non-null human-readable error_reason per BRQ-010, and Meeting.status MUST transition to FAILED per BRQ-008.", source:"BRQ-008, BRQ-010", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-016", properties:{rq_type:"behavioral", description:"On successful completion of TranscriptionJob, System MUST auto-create exactly one ProtocolGenerationJob with status=QUEUED, transcript_id pointing to the new Transcript, and prompt_template_version set to the current template version. Per BRQ-007.", source:"BRQ-007", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-017", properties:{rq_type:"behavioral", description:"Speaker name resolution MUST attempt to map each anonymous diarization label (Speaker 1, Speaker 2, ...) to a real name by analyzing self-introductions and addressed names within the transcript. Confident matches are substituted across full_text and recorded in speaker_map. Labels without a confident match remain 'Speaker N' and map to null in speaker_map. Per BRQ-021.", source:"BRQ-021", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-018", properties:{rq_type:"behavioral", description:"Language handling: when Meeting.language is null, the ASR engine MUST detect the language and the detected value MUST be recorded as Transcript.language. Meeting.language stays null per BRQ-005. When Meeting.language is set (RU or EN), it is passed as a hint and Transcript.language SHOULD match.", source:"BRQ-005", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-019", properties:{rq_type:"behavioral", description:"Transcript view MUST display each segment with its speaker label (resolved name from speaker_map or 'Speaker N' if unresolved) and minute/second timestamps.", source:"behavior", type:"functional", priority:"high", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-020", properties:{rq_type:"behavioral", description:"Transcript download produces a plain-text file (.txt) containing the verbatim transcript with speaker labels and timestamps. Filename pattern: '<meeting-title>-transcript.txt' (or filename fallback when title is null).", source:"behavior", type:"functional", priority:"medium", updated:datetime('2026-05-18T07:08:15.081Z'), status:"draft"}}, {id:"RQ-021", properties:{rq_type:"behavioral", description:"ProtocolGenerationJob lifecycle MUST follow: QUEUED -> IN_PROGRESS -> {COMPLETED, FAILED}. Terminal states immutable per BRQ-009.", source:"BRQ-009", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-022", properties:{rq_type:"behavioral", description:"LLM prompt template MUST be selected by Transcript.language per BRQ-013; the resulting protocol language MUST match the transcript language. Template version is recorded on the job.", source:"BRQ-013", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-023", properties:{rq_type:"validation", description:"Persisted Protocol MUST contain all four required sections per BRQ-011: Participants, Discussion Topics, Decisions, Action Items. If any section is missing in the LLM response, the job MUST be marked FAILED.", source:"BRQ-011", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-024", properties:{rq_type:"behavioral", description:"Action items SHOULD include assignee and deadline when these are stated in the meeting per BRQ-012. Best-effort extraction by the LLM; absence is acceptable.", source:"BRQ-012", type:"functional", priority:"medium", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-025", properties:{rq_type:"behavioral", description:"Initial Protocol on successful generation MUST be persisted with version=1, edit_count=0, generated_at=now. Meeting.status -> PROTOCOL_READY per BRQ-008.", source:"BRQ-008, BRQ-014, BRQ-015", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-026", properties:{rq_type:"behavioral", description:"On any failure during protocol generation (LLM error, parse error, missing required sections), job.status=FAILED with non-null error_reason (BRQ-010) and Meeting.status=FAILED (BRQ-008).", source:"BRQ-008, BRQ-010", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-027", properties:{rq_type:"behavioral", description:"Each save of an edited Protocol MUST increment version by exactly 1 per BRQ-014. Version is monotonically increasing.", source:"BRQ-014", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-028", properties:{rq_type:"behavioral", description:"Each save of an edited Protocol MUST increment edit_count by exactly 1 per BRQ-015. edit_count equals the number of manual saves performed since initial generation.", source:"BRQ-015", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-029", properties:{rq_type:"behavioral", description:"On first save, Meeting.status transitions PROTOCOL_READY -> EDITED (BRQ-008). Subsequent saves keep status=EDITED. last_edited_at is updated on every save.", source:"BRQ-008", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-030", properties:{rq_type:"behavioral", description:"All edits operate on canonical Markdown stored in Protocol.markdown_content per BRQ-018. Rendered preview is a derivation, never persisted.", source:"BRQ-018", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-031", properties:{rq_type:"behavioral", description:"The editor MUST warn the AUTHOR before navigating away with unsaved changes (browser-native or in-app confirmation).", source:"behavior", type:"functional", priority:"medium", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}] AS row
CREATE (n:Requirement{id: row.id}) SET n += row.properties;
UNWIND [{id:"RQ-032", properties:{rq_type:"behavioral", description:"PDF export is transient: the rendered PDF MUST NOT be persisted (BRQ-017). Each export re-renders from the canonical Markdown (BRQ-018).", source:"BRQ-017, BRQ-018", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"RQ-033", properties:{rq_type:"behavioral", description:"Exported PDF MUST include all four required sections per BRQ-011 (Participants, Discussion Topics, Decisions, Action Items). On render failure, no file is delivered and no state change is persisted.", source:"BRQ-011", type:"functional", priority:"high", updated:datetime('2026-05-18T07:09:54.787Z'), status:"draft"}}, {id:"ADR-001", properties:{decision:"Node 20 LTS + Fastify 5 + TypeScript + Zod via fastify-type-provider-zod for runtime validation.", created:datetime('2026-05-18T00:00:00Z'), context:"User preference (Fastify). NFR-001 requires chunked 500MB uploads, NFR-002 requires async job pipeline. Fastify excels at streaming uploads, has first-class Pino logging, and pairs cleanly with BullMQ.", alternatives:"NestJS (heavier, decorators add complexity); Express (slower streaming, no first-class typing); Hono (newer, smaller plugin ecosystem).", consequences:"Shared Zod schemas in shared/ workspace become single source of truth for DTOs.", title:"Backend: Fastify 5 + Node 20 LTS + TypeScript", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-002", properties:{decision:"PostgreSQL 16 with JSONB columns for segments/speaker_map. Prisma as ORM (excellent TS types, migrations).", created:datetime('2026-05-18T00:00:00Z'), context:"Job state transitions (uploading -> transcribing -> ... -> failed) require ACID per BRQ-008/009/010. Transcript.segments and Protocol.speaker_map are document-shaped.", alternatives:"Drizzle (lighter but less mature migrations), MongoDB (no ACID without transactions, schema drift risk), SQLite (single-writer bottleneck even for MVP).", consequences:"Prisma client shared via shared/ workspace between api and worker.", title:"Database & ORM: PostgreSQL 16 + Prisma", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-003", properties:{decision:"BullMQ over Redis 7 for queue management. Worker runs as a separate Node process (own Docker container) sharing the Prisma client via monorepo.", created:datetime('2026-05-18T00:00:00Z'), context:"BP-002 transcription and BP-004 protocol generation are long-running (minutes to hours). NFR-002 requires async. BRQ-009 requires terminal-state immutability.", alternatives:"pg-boss (DB-backed, simpler ops but slower fan-out); in-process queue (rejected, API latency would spike during ffmpeg).", consequences:"Job retry semantics map cleanly to ADR-004 manual-retry decision via BullMQ attempts cap.", title:"Job Queue: BullMQ + Redis 7, separate worker process", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-004", properties:{decision:"MinIO 2026 in Docker Compose. AWS SDK v3 S3 client used in code so swap to AWS S3 / Cloudflare R2 is a config change only.", created:datetime('2026-05-18T00:00:00Z'), context:"EXT-04 requires durable object storage. NFR-005 / BRQ-020 require retention until both Transcript and Protocol are produced. MVP needs single-VM deployment.", alternatives:"Local filesystem (rejected, no proper streaming API); AWS S3 from day 1 (rejected, adds cloud dependency for MVP).", consequences:"Recording.storage_uri uses s3://bucket/key shape; the same code path works against any S3-compatible backend.", title:"Object Storage: MinIO (S3-compatible, Dockerized)", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-005", properties:{decision:"@tus/server on Fastify (mounted under /api/upload), tus-js-client on the frontend. Bridge to MinIO via S3 multipart on chunk completion.", created:datetime('2026-05-18T00:00:00Z'), context:"NFR-001 requires 500MB chunked upload without timeout. Network flakiness must not force full re-upload.", alternatives:"Direct S3 multipart with presigned URLs (rejected, exposes storage credentials surface); custom chunk upload (rejected, reinvents TUS).", consequences:"Frontend dropzone uses tus-js-client; resumes automatically on disconnect.", title:"Chunked upload protocol: TUS", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-006", properties:{decision:"Deepgram Nova-3 (RU+EN + diarization in a single API call) wrapped behind an IAsrProvider TypeScript interface. The interface allows swapping to OpenRouter / AssemblyAI / self-hosted Whisper+pyannote later.", created:datetime('2026-05-18T00:00:00Z'), context:"EXT-02 requires speaker-attributed transcript with timestamps. BRQ-006 (1:1 TranscriptionJob per Recording) and BRQ-021 (speaker name resolution) require native diarization output. OpenRouter was evaluated but none of its ASR models expose speaker diarization as of 2026-05.", alternatives:"OpenRouter (rejected, no diarization); AssemblyAI Universal-3 (acceptable backup, slightly pricier); self-hosted Whisper + pyannote (rejected for MVP, GPU ops overhead).", consequences:"Worker holds the Deepgram client; IAsrProvider in shared/ workspace defines transcribe({audioUri, language}) returning normalized segments with speaker_label, start_ms, end_ms, text.", title:"ASR/Diarization: Deepgram Nova-3 behind IAsrProvider", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-007", properties:{decision:"kie.ai with two adapters: claude-sonnet-4-6 via POST /claude/v1/messages and gpt-5-4 via POST /codex/v1/responses. ILlmProvider interface in shared/; per-meeting model selection persisted on Meeting.llm_model. Default Claude Sonnet 4.6.", created:datetime('2026-05-18T00:00:00Z'), context:"EXT-03 requires LLM for structured protocol generation (BRQ-011 four sections, BRQ-013 source language). User wants both Anthropic and OpenAI lineage available; kie.ai exposes both behind separate endpoints with different request shapes.", alternatives:"Direct vendor APIs (rejected, user prefers single billing surface); OpenRouter (rejected, user explicitly chose kie.ai).", consequences:"Two adapter implementations; identical output schema (markdown + four required sections). Switching is just a Meeting.llm_model UI control.", title:"LLM: kie.ai with runtime-switchable Claude Sonnet 4.6 / GPT-5.4", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-008", properties:{decision:"Vite 5 + React 19 + TypeScript SPA. shadcn/ui + Tailwind CSS for components. TanStack Query v5 for data fetching and SSE bridge. React Router 7 for routing.", created:datetime('2026-05-18T00:00:00Z'), context:"Single-user internal MVP per NFR-007/NFR-009. No SEO or crawler discovery needed. Heavy client-side interactivity: file upload, markdown editor, SSE status. Astro was evaluated but its islands model fits content-first sites, not interactive apps.", alternatives:"Astro (rejected, islands hydration adds cost without benefit for interactive-heavy app); Next.js 15 (rejected, SSR overhead unnecessary for internal MVP).", consequences:"Web served as static files behind Fastify (or via separate nginx); API and Web deploy independently.", title:"Frontend: Vite 5 + React 19 + TypeScript (SPA)", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-009", properties:{decision:"Milkdown for WYSIWYG markdown editing (UC-301). react-markdown + remark-gfm for read-only rendering. PDF export via Puppeteer rendering an HTML/CSS template against the markdown source on demand; the rendered PDF is streamed back and never persisted.", created:datetime('2026-05-18T00:00:00Z'), context:"BRQ-018 markdown canonical, BRQ-017 PDF transient, BRQ-011 four required sections.", alternatives:"Pandoc (heavier, system dependency); md-to-pdf (less style control); Typst (less mature ecosystem).", consequences:"Worker container ships with chromium for Puppeteer; ~150MB image overhead.", title:"Markdown editing & PDF export", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-010", properties:{decision:"SSE via Fastify reply.raw stream; client subscribes with EventSource. TanStack Query bridges SSE events to query cache updates.", created:datetime('2026-05-18T00:00:00Z'), context:"NFR-002 requires non-blocking UI surfacing of job progress. BRQ-008 status lifecycle has well-defined one-way transitions.", alternatives:"WebSocket (rejected, full duplex unneeded); polling (rejected, latency and bandwidth waste).", consequences:"No socket server required; survives any reverse proxy that supports streaming responses.", title:"Realtime status: Server-Sent Events", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}, {id:"ADR-011", properties:{decision:"pnpm workspaces with packages: api/, worker/, web/, shared/ (Prisma, Zod schemas, provider interfaces). Docker Compose runs api + worker + postgres + redis + minio.", created:datetime('2026-05-18T00:00:00Z'), context:"API and Worker share Prisma client and Zod schemas; FE shares Zod-derived TS types. NFR-009 allows single-VM deployment.", alternatives:"Polyrepo (rejected, duplicate types); npm/yarn workspaces (acceptable, pnpm chosen for performance + strict isolation).", consequences:"Single docker-compose.yml is the source of truth for local dev and single-VM production; production swaps MinIO -> S3 via env vars only.", title:"Repo shape & deployment: pnpm monorepo + Docker Compose", type:"adr", priority:"MVP", updated:datetime('2026-05-18T00:00:00Z'), status:"approved"}}] AS row
CREATE (n:Requirement{id: row.id}) SET n += row.properties;
UNWIND [{_id:197, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:42:37.883Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the Meeting aggregate.", id:"Meeting-A01", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:198, properties:{internal:false, nullable:true, created:datetime('2026-05-18T06:42:37.883Z'), name:"title", data_type:"String", description:"Optional user-readable meeting title. Defaults to the source filename if not provided.", id:"Meeting-A02", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:199, properties:{internal:false, nullable:true, created:datetime('2026-05-18T06:42:37.883Z'), name:"language", data_type:"Enum", description:"Transcription language for the meeting (RU or EN). Null until resolved (per BRQ-005 auto-detect fallback during ASR).", id:"Meeting-A03", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:200, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:42:37.883Z'), name:"status", data_type:"Enum", description:"Pipeline-mirror status of the meeting (BRQ-008). Drives UI state and disables protocol actions before TRANSCRIPT_READY.", id:"Meeting-A04", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:201, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:42:37.883Z'), name:"uploaded_at", data_type:"DateTime", description:"Timestamp when the upload was initiated. Immutable.", id:"Meeting-A05", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:202, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:42:37.883Z'), name:"updated_at", data_type:"DateTime", description:"Timestamp of the last status transition or protocol edit. Used to sort the meeting catalog by recent activity.", id:"Meeting-A06", updated:datetime('2026-05-18T06:42:37.883Z')}}, {_id:214, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the Recording.", id:"Recording-A01", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:215, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"meeting_id", data_type:"Reference", description:"FK to the owning Meeting (ent-001). Also surfaced as a RELATES_TO edge in the graph.", id:"Recording-A02", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:216, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"filename", data_type:"String", description:"Original filename as supplied by the user at upload time.", id:"Recording-A03", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:217, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"size_bytes", data_type:"Int", description:"File size in bytes. MUST be <= 524,288,000 per BRQ-001 (500 MB).", id:"Recording-A04", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:218, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"mime_type", data_type:"Enum", description:"Container MIME type. Constrained by BRQ-002 to MP4/MKV/MOV.", id:"Recording-A05", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:219, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"storage_path", data_type:"String", description:"Object key in EXT-04 Object Storage where the raw video is persisted. System-managed.", id:"Recording-A06", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:220, properties:{internal:false, nullable:true, created:datetime('2026-05-18T06:46:25.641Z'), name:"duration_sec", data_type:"Int", description:"Video duration in seconds. Null until extracted during BP-002 audio extraction.", id:"Recording-A07", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:221, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:46:25.641Z'), name:"uploaded_at", data_type:"DateTime", description:"Timestamp when the upload completed successfully. Immutable.", id:"Recording-A08", updated:datetime('2026-05-18T06:46:25.641Z')}}, {_id:226, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the TranscriptionJob.", id:"TranscriptionJob-A01", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:227, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"meeting_id", data_type:"Reference", description:"FK to the owning Meeting (ent-001).", id:"TranscriptionJob-A02", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:228, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"recording_id", data_type:"Reference", description:"FK to the source Recording (ent-002). 1:1 relationship per BRQ-006.", id:"TranscriptionJob-A03", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:229, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"status", data_type:"Enum", description:"Job lifecycle status. Transitions: QUEUED -> IN_PROGRESS -> COMPLETED or FAILED. Terminal states are immutable (BRQ-009).", id:"TranscriptionJob-A04", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:230, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:48:25.348Z'), name:"error_reason", data_type:"String", description:"Human-readable error description. MUST be non-null when status=FAILED (BRQ-010).", id:"TranscriptionJob-A05", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:231, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:48:25.348Z'), name:"started_at", data_type:"DateTime", description:"Timestamp when the worker picked up the job. Null while QUEUED.", id:"TranscriptionJob-A06", updated:datetime('2026-05-18T06:48:25.348Z')}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:DomainAttribute;
UNWIND [{_id:232, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:48:25.348Z'), name:"completed_at", data_type:"DateTime", description:"Timestamp when the job reached a terminal state. Null while not yet COMPLETED/FAILED.", id:"TranscriptionJob-A07", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:233, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the Transcript.", id:"Transcript-A01", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:234, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"meeting_id", data_type:"Reference", description:"FK to the owning Meeting (ent-001).", id:"Transcript-A02", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:235, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"full_text", data_type:"String", description:"Verbatim transcript content. Structured Markdown/text containing per-segment speaker labels and minute/second timestamps.", id:"Transcript-A03", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:236, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"segments_count", data_type:"Int", description:"Total number of speaker-attributed segments in the transcript.", id:"Transcript-A04", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:237, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"speakers_count", data_type:"Int", description:"Number of distinct speakers detected by the diarization engine.", id:"Transcript-A05", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:238, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"language", data_type:"Enum", description:"Detected or confirmed language of the transcript (RU or EN). Result of ASR detection per BRQ-005 when Meeting.language is null.", id:"Transcript-A06", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:239, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:48:25.348Z'), name:"created_at", data_type:"DateTime", description:"Timestamp when the transcript was first persisted.", id:"Transcript-A07", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:240, properties:{internal:false, nullable:true, created:datetime('2026-05-18T06:48:25.348Z'), name:"speaker_map", data_type:"JSON", description:"Map of anonymous diarization labels to resolved names per BRQ-021. Example: {\"Speaker 1\": \"Ivan\", \"Speaker 2\": null}. Null means no resolutions attempted.", id:"Transcript-A08", updated:datetime('2026-05-18T06:48:25.348Z')}}, {_id:246, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the ProtocolGenerationJob.", id:"ProtocolGenerationJob-A01", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:247, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"meeting_id", data_type:"Reference", description:"FK to the owning Meeting (ent-001).", id:"ProtocolGenerationJob-A02", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:248, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"transcript_id", data_type:"Reference", description:"FK to the source Transcript (ent-004). One PGJ is auto-created per Transcript per BRQ-007.", id:"ProtocolGenerationJob-A03", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:249, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"status", data_type:"Enum", description:"Job lifecycle status. Reuses ENUM-JobStatus. Terminal states are immutable (BRQ-009).", id:"ProtocolGenerationJob-A04", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:250, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:49:22.459Z'), name:"error_reason", data_type:"String", description:"Human-readable error description. MUST be non-null when status=FAILED (BRQ-010). Typical causes: LLM timeout, token-limit, malformed response.", id:"ProtocolGenerationJob-A05", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:251, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"prompt_template_version", data_type:"String", description:"Version identifier of the LLM prompt template used for this generation; enables reproducibility audits.", id:"ProtocolGenerationJob-A06", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:252, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:49:22.459Z'), name:"started_at", data_type:"DateTime", description:"Timestamp when the worker picked up the job. Null while QUEUED.", id:"ProtocolGenerationJob-A07", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:253, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:49:22.459Z'), name:"completed_at", data_type:"DateTime", description:"Timestamp when the job reached a terminal state. Null while not yet COMPLETED/FAILED.", id:"ProtocolGenerationJob-A08", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:254, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"id", data_type:"UUID", description:"Surrogate primary key for the Protocol.", id:"Protocol-A01", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:255, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"meeting_id", data_type:"Reference", description:"FK to the owning Meeting (ent-001).", id:"Protocol-A02", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:256, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"markdown_content", data_type:"String", description:"Canonical Markdown content of the protocol (BRQ-018). MUST contain the four required sections per BRQ-011: Participants, Discussion Topics, Decisions, Action Items.", id:"Protocol-A03", updated:datetime('2026-05-18T06:49:22.459Z')}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:DomainAttribute;
UNWIND [{_id:257, properties:{internal:true, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"generated_at", data_type:"DateTime", description:"Timestamp when the protocol was first produced by the LLM pipeline. Immutable.", id:"Protocol-A04", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:258, properties:{internal:true, nullable:true, created:datetime('2026-05-18T06:49:22.459Z'), name:"last_edited_at", data_type:"DateTime", description:"Timestamp of the most recent manual save. Null until the user edits at least once.", id:"Protocol-A05", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:259, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"edit_count", data_type:"Int", description:"Number of manual saves performed since initial generation (BRQ-015). Starts at 0.", id:"Protocol-A06", updated:datetime('2026-05-18T06:49:22.459Z')}}, {_id:260, properties:{internal:false, nullable:false, created:datetime('2026-05-18T06:49:22.459Z'), name:"version", data_type:"Int", description:"Monotonically incrementing version number. Starts at 1 on generation; incremented by 1 on each save (BRQ-014).", id:"Protocol-A07", updated:datetime('2026-05-18T06:49:22.459Z')}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:DomainAttribute;
UNWIND [{id:"W0", properties:{number:0, created:datetime('2026-05-18T08:40:46.825Z'), name:"Foundation & Infrastructure", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}, {id:"W1", properties:{number:1, created:datetime('2026-05-18T08:40:46.825Z'), name:"Core BE: Catalog + Upload", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}, {id:"W2", properties:{number:2, created:datetime('2026-05-18T08:40:46.825Z'), name:"Core FE + Detail BE + Transcription Pipeline", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}, {id:"W3", properties:{number:3, created:datetime('2026-05-18T08:40:46.825Z'), name:"Detail/Delete BE+FE + Transcript + Protocol Pipeline", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}, {id:"W4", properties:{number:4, created:datetime('2026-05-18T08:40:46.825Z'), name:"Delete/Transcript FE + Protocol Editor BE", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}, {id:"W5", properties:{number:5, created:datetime('2026-05-18T08:40:46.825Z'), name:"Protocol Editor FE + PDF Export", updated:datetime('2026-05-18T08:40:46.825Z'), status:"pending"}}] AS row
CREATE (n:Wave{id: row.id}) SET n += row.properties;
UNWIND [{_id:169, properties:{primary_actor:"ROL-01", source_bp:"BP-001", created:date('2026-05-17'), description:"User selects a video file, optionally sets a language hint; system validates the file, uploads to object storage, persists Meeting + Recording, enqueues TranscriptionJob.", label:"Upload video and create meeting", id:"UC-001", updated:date('2026-05-17'), status:"candidate"}}, {_id:170, properties:{primary_actor:"System", source_bp:"BP-002", created:date('2026-05-17'), description:"Automated pipeline: dequeue job, fetch video from storage, extract audio, submit to ASR/diarization engine (EXT-02), receive speaker-attributed segments, assemble and persist Transcript.", label:"Transcribe audio with diarization", id:"UC-002", updated:date('2026-05-17'), status:"candidate"}}, {_id:171, properties:{primary_actor:"System", source_bp:"BP-002-S07B", created:date('2026-05-17'), description:"After diarization, system scans the transcript for self-introductions and addressed names. Anonymous speaker labels (Speaker 1, Speaker 2...) are substituted with resolved names where confidence is sufficient. Unresolved labels remain.", label:"Resolve speaker names in transcript", id:"UC-003", updated:date('2026-05-17'), status:"candidate"}}, {_id:172, properties:{primary_actor:"System", source_bp:"BP-004", created:date('2026-05-17'), description:"On transcript-ready event, system loads transcript, selects prompt template by language, submits to LLM (EXT-03), parses response into structured Markdown protocol with required sections, persists.", label:"Generate meeting protocol via LLM", id:"UC-004", updated:date('2026-05-17'), status:"candidate"}}, {_id:173, properties:{primary_actor:"System", source_bp:"BP-002-S09 + BP-004-S10", created:date('2026-05-17'), description:"Pipeline failure handling: mark job as failed with error_reason, update Meeting status to failed, surface in UI. Retry strategy (manual vs. auto) TBD.", id:"UC-005", label:"Handle transcription and protocol failures", updated:date('2026-05-17'), status:"candidate"}}, {_id:174, properties:{primary_actor:"ROL-01", source_bp:"BP-003", created:date('2026-05-17'), description:"User views and downloads the verbatim transcript from the recording detail page.", label:"View and download transcript", id:"UC-006", updated:date('2026-05-17'), status:"candidate"}}, {_id:175, properties:{primary_actor:"ROL-01", source_bp:"BP-005", created:date('2026-05-17'), description:"User opens the generated protocol in an in-app Markdown editor, reviews and edits content, saves changes. Save increments version and edit_count.", id:"UC-007", label:"Review and edit protocol in Markdown editor", updated:date('2026-05-17'), status:"candidate"}}, {_id:176, properties:{primary_actor:"ROL-01", source_bp:"BP-006", created:date('2026-05-17'), description:"User clicks Export to PDF; system renders Markdown protocol to PDF via export script and delivers as a download.", label:"Export protocol as PDF", id:"UC-008", updated:date('2026-05-17'), status:"candidate"}}, {_id:177, properties:{primary_actor:"ROL-01", source_bp:"cross-cutting", created:date('2026-05-17'), description:"Cross-cutting: UI surfaces Meeting.status reflecting the pipeline stage (uploading -> transcribing -> transcript_ready -> protocol_generating -> protocol_ready -> edited | failed).", label:"Display meeting processing status", id:"UC-009", updated:date('2026-05-17'), status:"candidate"}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:UCStub;
UNWIND [{id:"OBJ-001-ST01", properties:{name:"uploading", description:"File upload is in progress"}}, {id:"OBJ-001-ST02", properties:{name:"transcribing", description:"Transcription job is queued or running"}}, {id:"OBJ-001-ST03", properties:{name:"transcript_ready", description:"Transcript has been produced and persisted"}}, {id:"OBJ-001-ST04", properties:{name:"protocol_generating", description:"Protocol generation job is queued or running"}}, {id:"OBJ-001-ST05", properties:{name:"protocol_ready", description:"Protocol has been generated and persisted"}}, {id:"OBJ-001-ST06", properties:{name:"edited", description:"Protocol has been manually edited at least once; repeating state on each save"}}, {id:"OBJ-001-ST07", properties:{name:"failed", description:"Non-recoverable error in the transcription or generation pipeline"}}, {id:"OBJ-003-ST01", properties:{name:"queued", description:"Job created, waiting for a worker"}}, {id:"OBJ-003-ST02", properties:{name:"in_progress", description:"Worker is running ASR/diarization"}}, {id:"OBJ-003-ST03", properties:{name:"completed", description:"Transcript produced and persisted successfully"}}, {id:"OBJ-003-ST04", properties:{name:"failed", description:"Job terminated with non-recoverable error"}}, {id:"OBJ-005-ST01", properties:{name:"queued", description:"Job created, waiting for a worker"}}, {id:"OBJ-005-ST02", properties:{name:"in_progress", description:"Worker executing LLM request, awaiting response"}}, {id:"OBJ-005-ST03", properties:{name:"completed", description:"Protocol produced and persisted successfully"}}, {id:"OBJ-005-ST04", properties:{name:"failed", description:"Job terminated with non-recoverable error (LLM timeout, token limit, etc.)"}}] AS row
CREATE (n:EntityState{id: row.id}) SET n += row.properties;
UNWIND [{_id:203, properties:{created:datetime('2026-05-18T06:42:50.827Z'), name:"MeetingStatus", description:"Pipeline-mirror status for a Meeting aggregate (BRQ-008). Drives UI state and gating of downstream actions.", id:"ENUM-MeetingStatus", updated:datetime('2026-05-18T06:42:50.827Z')}}, {_id:211, properties:{created:datetime('2026-05-18T06:42:59.421Z'), name:"MeetingLanguage", description:"Supported transcription/protocol language for a Meeting (BRQ-004). Null on the Meeting indicates pending auto-detect.", id:"ENUM-MeetingLanguage", updated:datetime('2026-05-18T06:42:59.421Z')}}, {_id:222, properties:{created:datetime('2026-05-18T06:46:35.849Z'), name:"VideoMimeType", description:"Allowed container MIME types for uploaded recordings. Sourced from BRQ-002.", id:"ENUM-VideoMimeType", updated:datetime('2026-05-18T06:46:35.849Z')}}, {_id:241, properties:{created:datetime('2026-05-18T06:48:36.403Z'), name:"JobStatus", description:"Async job lifecycle status. Shared between TranscriptionJob and ProtocolGenerationJob. Terminal states are immutable (BRQ-009).", id:"ENUM-JobStatus", updated:datetime('2026-05-18T06:48:36.403Z')}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:Enumeration;
UNWIND [{id:"UC-001", properties:{actor:"AUTHOR", user_story:"As an Author, I want to see all my meetings with their current pipeline status, so I know which are ready and which are still processing.", system_uc:true, created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", name:"View meeting catalog", priority:"MVP", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:true, acceptance_criteria:["GIVEN at least one Meeting exists, WHEN I open the catalog, THEN I see a list of meetings sorted by updated_at descending.", "EACH row shows: title (or filename fallback), status badge (per ENUM-MeetingStatus), language, uploaded_at, duration if available.", "GIVEN a meeting in a transient state (UPLOADING / TRANSCRIBING / PROTOCOL_GENERATING), THEN its row shows a progress indicator that auto-refreshes."], status:"identified"}}, {id:"UC-002", properties:{actor:"AUTHOR", user_story:"As an Author, I want to open a meeting and see its status, recording info, and links to transcript/protocol, so I have a single entry point per meeting.", system_uc:true, created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", name:"View meeting detail", priority:"MVP", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:true, acceptance_criteria:["GIVEN a Meeting, WHEN I open its detail page, THEN I see: title, language, status, recording metadata (filename, size, duration), and current job error_reason when FAILED.", "GIVEN status >= TRANSCRIPT_READY, THEN a link to view the transcript is visible (UC-201).", "GIVEN status >= PROTOCOL_READY, THEN a link to review/edit the protocol is visible (UC-301)."], status:"identified"}}, {id:"UC-003", properties:{actor:"AUTHOR", user_story:"As an Author, I want to delete a meeting and all its derived artifacts, so I can clean up obsolete or sensitive recordings.", system_uc:true, created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", name:"Delete meeting", priority:"MVP", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:true, acceptance_criteria:["GIVEN any Meeting, WHEN I confirm deletion, THEN the Meeting, its Recording (storage object removed), Transcript, Protocol, and all jobs are deleted.", "GIVEN deletion succeeds, THEN I am returned to the catalog (UC-001) with a confirmation toast.", "WHILE a job is IN_PROGRESS, deletion is disabled (or shows confirmation that an in-flight job will be marked FAILED)."], status:"identified"}}, {id:"UC-100", properties:{actor:"AUTHOR", user_story:"As an Author, I want to upload a 300-500 MB meeting video with an optional language hint, so the system starts transcription.", created:datetime('2026-05-18T07:01:52.727Z'), source_bp:"BP-001", detail_status:"complete", name:"Upload meeting video", priority:"MVP", updated:datetime('2026-05-18T07:06:59.315Z'), has_ui:true, acceptance_criteria:["GIVEN a valid MP4/MKV/MOV file <= 500 MB (BRQ-001, BRQ-002), WHEN I upload, THEN the system accepts, creates Meeting + Recording + TranscriptionJob, and shows status UPLOADING -> TRANSCRIBING.", "GIVEN a file > 500 MB or wrong MIME, WHEN I attempt upload, THEN the system rejects before storage with a clear error.", "GIVEN a corrupt file (BRQ-003), WHEN validation fails, THEN the system rejects with a user-facing error.", "I can choose RU or EN as the language hint; leaving it blank means auto-detect (BRQ-005)."], status:"identified"}}, {id:"UC-200", properties:{actor:"SYSTEM", user_story:"As the SYSTEM, I dequeue a queued TranscriptionJob, run ASR + diarization on the recording, resolve speaker names, and persist a verbatim Transcript with status updates.", created:datetime('2026-05-18T07:01:52.727Z'), source_bp:"BP-002", detail_status:"complete", name:"Process transcription pipeline", priority:"MVP", updated:datetime('2026-05-18T07:08:18.704Z'), has_ui:false, acceptance_criteria:["GIVEN a QUEUED TranscriptionJob, WHEN a worker picks it up, THEN job.status -> IN_PROGRESS and started_at is set.", "GIVEN ASR succeeds, THEN Transcript is persisted, speakers resolved per BRQ-021, Meeting.status -> TRANSCRIPT_READY, job.status -> COMPLETED, and a ProtocolGenerationJob is auto-created (BRQ-007).", "GIVEN ASR fails, THEN job.status -> FAILED with non-null error_reason (BRQ-010), and Meeting.status -> FAILED; terminal states are immutable (BRQ-009)."], status:"identified"}}, {id:"UC-201", properties:{created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", priority:"MVP", actor:"AUTHOR", user_story:"As an Author, I want to view the verbatim transcript with speaker labels and download it as a text file, so I have a permanent meeting record.", system_uc:true, source_bp:"BP-003", name:"View and download transcript", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:true, acceptance_criteria:["GIVEN Meeting.status >= TRANSCRIPT_READY, WHEN I open the transcript view, THEN I see segments with speaker labels, timestamps, and counts (segments_count, speakers_count).", "I can download the transcript as a text file with a one-click action.", "Unresolved speakers (BRQ-021) are shown as 'Speaker N'; resolved speakers show the real name."], status:"identified"}}, {id:"UC-300", properties:{actor:"SYSTEM", user_story:"As the SYSTEM, when a transcript becomes ready I auto-trigger LLM-based protocol generation and persist the Markdown result with status updates.", created:datetime('2026-05-18T07:01:52.727Z'), source_bp:"BP-004", detail_status:"complete", name:"Generate protocol pipeline", priority:"MVP", updated:datetime('2026-05-18T07:10:00.406Z'), has_ui:false, acceptance_criteria:["GIVEN a Transcript is COMPLETED, THEN a ProtocolGenerationJob is auto-created per BRQ-007 with status=QUEUED.", "GIVEN a worker runs the job, THEN it loads the transcript, selects the prompt template by language (BRQ-013), calls the LLM, parses the response, and validates required sections (BRQ-011).", "GIVEN LLM succeeds AND all required sections are present, THEN Protocol is persisted (markdown, version=1, edit_count=0), Meeting.status -> PROTOCOL_READY, job.status -> COMPLETED.", "GIVEN LLM fails OR response is invalid, THEN job.status -> FAILED with error_reason, Meeting.status -> FAILED."], status:"identified"}}, {id:"UC-301", properties:{created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", priority:"MVP", actor:"AUTHOR", user_story:"As an Author, I want to review the generated protocol and edit it in a Markdown editor, so I can correct LLM mistakes before sharing.", system_uc:true, source_bp:"BP-005", name:"Review and edit protocol", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:true, acceptance_criteria:["GIVEN Meeting.status in {PROTOCOL_READY, EDITED}, WHEN I open the protocol, THEN it loads in a Markdown editor with rendered preview.", "WHEN I save changes, THEN Protocol.markdown_content is updated, version increments by 1 (BRQ-014), edit_count increments by 1 (BRQ-015), last_edited_at is set, and Meeting.status -> EDITED.", "All edits operate on the canonical Markdown (BRQ-018); preview is a derivation."], status:"identified"}}, {id:"UC-302", properties:{created:datetime('2026-05-18T07:01:52.727Z'), detail_status:"complete", priority:"MVP", actor:"AUTHOR", user_story:"As an Author, I want to export the protocol as a PDF, so I can distribute it as a polished document. [Note: triggered as an action from UC-002 detail and UC-301 editor; no dedicated screen.]", system_uc:true, source_bp:"BP-006", name:"Export protocol to PDF", updated:datetime('2026-05-18T07:21:52.04Z'), has_ui:false, acceptance_criteria:["GIVEN Meeting.status in {PROTOCOL_READY, EDITED}, WHEN I click 'Export PDF', THEN the system renders the current Markdown to PDF and delivers it as a download.", "The rendered PDF is NOT persisted (BRQ-017); each export re-renders from canonical Markdown.", "The exported document includes all four required sections (BRQ-011): Participants, Discussion Topics, Decisions, Action Items."], status:"identified"}}] AS row
CREATE (n:UseCase{id: row.id}) SET n += row.properties;
UNWIND [{id:"DFL-001", properties:{data_description:"Raw video file (300-500 MB) containing the meeting recording, uploaded by the user", name:"Meeting video file upload", direction:"IN"}}, {id:"DFL-002", properties:{data_description:"Complete timestamped transcript with speaker labels (who said what at which minute/second), delivered to the user for download", name:"Verbatim speaker-attributed transcript", direction:"OUT"}}, {id:"DFL-003", properties:{data_description:"Structured meeting protocol: participants list, discussion topics, decisions made, action items with assignees and deadlines, delivered to the user for download", name:"Meeting protocol", direction:"OUT"}}, {id:"DFL-004", properties:{data_description:"Extracted audio stream (or reference to stored file) sent to the ASR/diarization engine for processing", name:"Audio data for transcription", direction:"OUT"}}, {id:"DFL-005", properties:{data_description:"Transcript segments returned by ASR/diarization: each contains speaker ID, start/end timestamps, and spoken text", name:"Speaker-attributed transcript segments", direction:"IN"}}, {id:"DFL-006", properties:{data_description:"Full verbatim transcript with speaker labels sent to the LLM for extraction of topics, decisions, action items", name:"Transcript text for protocol generation", direction:"OUT"}}, {id:"DFL-007", properties:{data_description:"Structured meeting protocol returned by the LLM: participants, topics, decisions, action items with assignees and deadlines", name:"Generated meeting protocol", direction:"IN"}}, {id:"DFL-008", properties:{data_description:"Raw video/audio binary written to object storage for durable retention during asynchronous processing", name:"Video file write to storage", direction:"OUT"}}, {id:"DFL-009", properties:{data_description:"Video or extracted audio file retrieved from object storage to be passed to the ASR/diarization engine", name:"Video file retrieval from storage", direction:"IN"}}] AS row
CREATE (n:DataFlow{id: row.id}) SET n += row.properties;
UNWIND [{id:"OBJ-001", properties:{created:date('2026-05-17'), name:"Meeting", description:"Root aggregate representing a single meeting being processed. Owns Recording, Transcript, Protocol. Top-level object referenced by all downstream entities.", stereotype:"aggregate", updated:date('2026-05-17'), status:"draft"}}, {id:"OBJ-002", properties:{created:date('2026-05-17'), name:"Recording", description:"Metadata for the uploaded video file. Tracks filename, size, MIME, object storage path, and optional duration. Physical file in EXT-04.", stereotype:"entity", updated:date('2026-05-17'), status:"draft"}}, {id:"OBJ-003", properties:{created:date('2026-05-17'), name:"TranscriptionJob", description:"Async job tracking the ASR+diarization pipeline for a recording. Used to detect failure and surface error details.", stereotype:"job", updated:date('2026-05-17'), status:"draft"}}, {id:"OBJ-004", properties:{created:date('2026-05-17'), name:"Transcript", description:"Persisted verbatim speaker-attributed transcript from ASR+diarization. Segments stored inline as structured content rather than separate entities at MVP scope.", stereotype:"document", updated:date('2026-05-17'), status:"draft"}}, {id:"OBJ-005", properties:{created:date('2026-05-17'), name:"ProtocolGenerationJob", description:"Async job tracking LLM-based protocol generation for a transcript. Created automatically when transcription job completes.", stereotype:"job", updated:date('2026-05-17'), status:"draft"}}, {id:"OBJ-006", properties:{created:date('2026-05-17'), name:"Protocol", description:"Persisted meeting protocol Markdown produced by LLM and optionally refined by user. Sections: participants, topics, decisions, action items with assignees/deadlines. Version-incremented on each save.", stereotype:"document", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:BusinessEntity{id: row.id}) SET n += row.properties;
UNWIND [{id:"SYS-001", properties:{in_scope:["Video file upload (300-500 MB)", "Audio extraction from video", "Automatic Speech Recognition (ASR) with speaker diarization", "Verbatim transcript generation with per-speaker timestamps", "Meeting protocol generation: participants list, discussion topics, decisions, action items with assignees and deadlines", "Download / export of both artifacts by the user", "Markdown protocol format with in-app rendered view component", "In-app editing of the protocol (markdown editor)", "PDF export of the protocol (via export script)", "Bilingual support: Russian and English (per-upload)"], success_criteria:["User can upload a 300-500 MB video and receive a verbatim speaker-attributed transcript", "User can receive a structured meeting protocol with participants, topics, decisions, and action items", "Both artifacts are produced without manual intervention after upload", "Timestamps in transcript are accurate to the second"], created:date('2026-05-17'), name:"Transcrib", out_of_scope:["Real-time / live meeting transcription (batch processing only)", "Video playback or video editing", "User authentication and access management (no multi-tenancy assumed)", "Payment, billing, or subscription management", "Mobile native applications", "Integration with calendar or meeting platforms (e.g. Zoom, Teams)", "Sending or distributing the protocol to participants automatically"], updated:date('2026-05-17'), constraints:["Input files up to 300-500 MB must be handled without timeout", "Tech stack is TBD - no stack-specific constraints defined yet", "Processing may be asynchronous due to large file sizes and ASR latency", "Languages supported: Russian + English", "No processing-time SLA: async, best effort", "Protocol stored and edited as Markdown; PDF is export-only"], assumptions:["[assumption] A single user role (Meeting Participant) covers the primary stakeholder", "[assumption] An external ASR/diarization engine is required; vendor/model TBD", "[assumption] An LLM-based service is required for protocol generation; provider TBD", "[assumption] A file/object storage service is required to hold large video files; service TBD", "[assumption] One video at a time per user session; queue/parallelism design TBD"], status:"draft", goals:["Transcribe audio from large meeting video files (300-500 MB) with speaker diarization", "Produce a verbatim, speaker-attributed transcript with minute/second timestamps", "Generate a structured meeting protocol: participants, topics discussed, decisions made, action items with assignees and deadlines"]}}] AS row
CREATE (n:SystemContext{id: row.id}) SET n += row.properties;
UNWIND [{id:"OBJ-001-A01", properties:{name:"id", description:"Unique meeting identifier", type:"UUID", required:true}}, {id:"OBJ-001-A02", properties:{name:"title", description:"Optional human-readable meeting title (user-supplied or auto-derived from filename)", type:"String", required:false}}, {id:"OBJ-001-A03", properties:{name:"language", description:"Transcription language hint: RU | EN | auto", type:"Enum", required:true}}, {id:"OBJ-001-A04", properties:{name:"uploaded_at", description:"Timestamp when the upload was initiated", type:"DateTime", required:true}}, {id:"OBJ-001-A05", properties:{name:"status", description:"Current lifecycle status (see states OBJ-001-ST01..ST07)", type:"Enum", required:true}}, {id:"OBJ-002-A01", properties:{name:"id", description:"Unique recording identifier", type:"UUID", required:true}}, {id:"OBJ-002-A02", properties:{name:"meeting_id", description:"Foreign key to owning Meeting (OBJ-001)", type:"UUID", required:true}}, {id:"OBJ-002-A03", properties:{name:"filename", description:"Original filename as uploaded by the user", type:"String", required:true}}, {id:"OBJ-002-A04", properties:{name:"size_bytes", description:"File size in bytes", type:"Long", required:true}}, {id:"OBJ-002-A05", properties:{name:"mime_type", description:"MIME type of the uploaded file (e.g., video/mp4)", type:"String", required:true}}, {id:"OBJ-002-A06", properties:{name:"storage_path", description:"Object storage path/key where the raw file is persisted (EXT-04)", type:"String", required:true}}, {id:"OBJ-002-A07", properties:{name:"duration_sec", description:"Video duration in seconds; populated after audio extraction in BP-002", type:"Integer", required:false}}, {id:"OBJ-002-A08", properties:{name:"uploaded_at", description:"Timestamp when the upload completed successfully", type:"DateTime", required:true}}, {id:"OBJ-003-A01", properties:{name:"id", description:"Unique job identifier", type:"UUID", required:true}}, {id:"OBJ-003-A02", properties:{name:"meeting_id", description:"Foreign key to owning Meeting (OBJ-001)", type:"UUID", required:true}}, {id:"OBJ-003-A03", properties:{name:"recording_id", description:"Foreign key to the Recording being processed (OBJ-002)", type:"UUID", required:true}}, {id:"OBJ-003-A04", properties:{name:"status", description:"Job lifecycle status (see states OBJ-003-ST01..ST04)", type:"Enum", required:true}}, {id:"OBJ-003-A05", properties:{name:"error_reason", description:"Human-readable error description when status = failed", type:"String", required:false}}, {id:"OBJ-003-A06", properties:{name:"started_at", description:"Timestamp when the worker picked up the job", type:"DateTime", required:false}}, {id:"OBJ-003-A07", properties:{name:"completed_at", description:"Timestamp when the job reached a terminal state", type:"DateTime", required:false}}] AS row
