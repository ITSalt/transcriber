8:41:16.385Z'), status:"done"}}, {id:"UC-201-FE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-fe", uc_ref:"UC-201", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", phase_review_fe:"approved", title:"Transcript view page + download button", type:"uc-fe", priority:"high", wave:4, last_reconciled:"2026-05-18", phase_fe:"approved", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-300-BE", properties:{phase_qa:"skip", agent:"nacl-tl-dev-be", uc_ref:"UC-300", created:datetime('2026-05-18T08:41:16.385Z'), phase_5_outcome:"SKIP", title:"Protocol generation worker pipeline (LLM + section validation)", type:"uc-be", priority:"high", wave:3, phase_review_be:"approved", phase_be:"approved", phase_5_reason:"API keys not provided; provider E2E deferred", last_reconciled:"2026-05-18", phase_5_recorded:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"verified-pending"}}, {id:"UC-301-BE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-be", uc_ref:"UC-301", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", title:"Protocol editor save API (version/edit_count increment)", type:"uc-be", priority:"high", wave:4, phase_review_be:"approved", phase_be:"approved", last_reconciled:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-301-FE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-fe", uc_ref:"UC-301", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", phase_review_fe:"approved", title:"Protocol editor page (Milkdown WYSIWYG + preview)", type:"uc-fe", priority:"high", wave:5, last_reconciled:"2026-05-18", phase_fe:"approved", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-302-BE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-be", uc_ref:"UC-302", created:datetime('2026-05-18T08:41:16.385Z'), title:"PDF export endpoint (Puppeteer render, transient)", priority:"medium", type:"uc-be", wave:5, phase_review_be:"approved", phase_be:"approved", last_reconciled:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}] AS row
