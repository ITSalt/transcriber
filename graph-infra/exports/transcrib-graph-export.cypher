:begin
CREATE CONSTRAINT ba_business_entity_id FOR (node:BusinessEntity) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_business_process_id FOR (node:BusinessProcess) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_business_role_id FOR (node:BusinessRole) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_business_rule_id FOR (node:BusinessRule) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_data_flow_id FOR (node:DataFlow) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_entity_attribute_id FOR (node:EntityAttribute) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_entity_state_id FOR (node:EntityState) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_external_entity_id FOR (node:ExternalEntity) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_glossary_term_id FOR (node:GlossaryTerm) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_process_group_id FOR (node:ProcessGroup) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_stakeholder_id FOR (node:Stakeholder) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_system_context_id FOR (node:SystemContext) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ba_workflow_step_id FOR (node:WorkflowStep) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_domain_entity_attr_id FOR (node:DomainEntityAttribute) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_domain_entity_id FOR (node:DomainEntity) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_domain_entity_state_id FOR (node:DomainEntityState) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_field_id FOR (node:Field) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_form_id FOR (node:Form) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_module_id FOR (node:Module) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_permission_id FOR (node:Permission) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_requirement_id FOR (node:Requirement) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_screen_id FOR (node:Screen) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_system_role_id FOR (node:SystemRole) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_ui_component_id FOR (node:UIComponent) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT sa_use_case_id FOR (node:UseCase) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT tl_api_contract_id FOR (node:ApiContract) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT tl_task_id FOR (node:Task) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT tl_wave_id FOR (node:Wave) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT UNIQUE_IMPORT_NAME FOR (node:`UNIQUE IMPORT LABEL`) REQUIRE (node.`UNIQUE IMPORT ID`) IS UNIQUE;
:commit
CALL db.awaitIndexes(300);
:begin
UNWIND [{id:"GLO-001", properties:{aliases:["Встреча", "Session"], created:date('2026-05-17'), name:"Meeting", context:"Used throughout all processes (BP-001..BP-006); top-level aggregate (OBJ-001).", definition:"A single business meeting whose recording is uploaded into the system for processing. The root object that owns the recording, transcript, and protocol throughout its lifecycle.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-002", properties:{aliases:["Видеозапись", "Запись", "Video File"], created:date('2026-05-17'), name:"Recording", context:"Created in BP-001 (Upload); consumed in BP-002 (Transcription). OBJ-002.", definition:"The video file uploaded by the Author that captures the meeting. Physical file in object storage; metadata tracked as the Recording entity.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-003", properties:{aliases:["Транскрипт", "Пословная транскрибация", "Verbatim Transcript"], created:date('2026-05-17'), name:"Transcript", context:"Produced by BP-002; consumed by BP-003 and BP-004. OBJ-004.", definition:"The verbatim, speaker-attributed text output of the transcription pipeline. Full spoken content with speaker labels and per-segment timestamps. Sometimes called \"verbatim transcript\" to distinguish from a summarized protocol.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-004", properties:{aliases:["Диаризация спикеров", "Diarization"], created:date('2026-05-17'), name:"Speaker Diarization", context:"Performed inside BP-002 by the ASR/Diarization Engine (EXT-02). Output feeds into speaker-attributed transcript segments.", definition:"The automated process of partitioning an audio stream into segments and labeling each with a speaker identity (Speaker 1, Speaker 2). Answers \"who spoke when\" and is a required step of the transcription pipeline.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-005", properties:{aliases:["Сегмент транскрипта", "Transcript Segment"], created:date('2026-05-17'), name:"Speaker Segment", context:"Produced by diarization inside BP-002; stored as structured content within OBJ-004 (Transcript) at MVP.", definition:"A contiguous block of speech attributed to one speaker, with start/end timestamps, speaker label, and verbatim text. Multiple segments together form the Transcript.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-006", properties:{aliases:["Протокол встречи", "Protocol", "Minutes"], created:date('2026-05-17'), name:"Meeting Protocol", context:"Produced by BP-004; edited in BP-005; exported in BP-006. OBJ-006.", definition:"A structured summary document produced from the transcript by the LLM pipeline. Contains sections for participants, discussion topics, decisions made, and action items with assignees and deadlines. Stored as Markdown, exportable to PDF.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-007", properties:{aliases:["Протокол"], created:date('2026-05-17'), name:"Protocol", context:"Appears in entity names (OBJ-006), process names (BP-004/005/006), and UI labels.", definition:"Short-form alias for Meeting Protocol (GLO-006). Used interchangeably in code and UI labels.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-008", properties:{aliases:["Поручение", "Задача", "Task"], created:date('2026-05-17'), name:"Action Item", context:"Captured as a section within OBJ-006; extracted during BP-004.", definition:"A task agreed during the meeting, assigned to a named person with a deadline. Extracted by the LLM from the transcript; appears as a dedicated section of the protocol.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-009", properties:{aliases:["Решение"], created:date('2026-05-17'), name:"Decision", context:"Captured as a section within OBJ-006; extracted during BP-004.", definition:"A conclusion or resolution reached during the meeting, explicitly recorded in the protocol. Distinct from action items in that decisions represent outcomes rather than future tasks.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-010", properties:{aliases:["Тема обсуждения", "Вопрос", "Agenda Item"], created:date('2026-05-17'), name:"Discussion Topic", context:"Captured as a section within OBJ-006; extracted during BP-004.", definition:"A distinct agenda point or subject discussed during the meeting. The LLM groups related transcript content under topics, which become named sections of the protocol.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-011", properties:{aliases:["Участник", "Attendee", "Speaker"], created:date('2026-05-17'), name:"Participant", context:"Derived from speaker segments in OBJ-004; surfaced in OBJ-006.", definition:"A person who took part in the meeting. Identified from the transcript by the diarization engine (speaker labels) and optionally mapped to names. Listed in a dedicated section of the protocol.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-012", properties:{aliases:["Автор", "Uploader"], created:date('2026-05-17'), name:"Author", context:"ROL-01; performs BP-001, BP-003, BP-005, BP-006.", definition:"Business role representing the person who uploaded the recording and owns all derived artifacts. At MVP the only active human role.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-013", properties:{aliases:["Проверяющий", "Читатель"], created:date('2026-05-17'), name:"Reviewer", context:"ROL-02; assumption — no distinct system behavior at MVP.", definition:"Business role for a meeting participant who reads and validates the generated protocol. At MVP no technical distinction from Author; modeled for future access-control design.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-014", properties:{aliases:["Пайплайн транскрибации", "Transcription Flow"], created:date('2026-05-17'), name:"Transcription Pipeline", context:"Corresponds to BP-002 and its workflow steps.", definition:"End-to-end automated sequence transforming an uploaded video recording into a verbatim speaker-attributed transcript. Encompasses audio extraction, ASR, and diarization.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-015", properties:{aliases:["Жизненный цикл протокола"], created:date('2026-05-17'), name:"Protocol Lifecycle", context:"Spans BP-004/005/006; states tracked via OBJ-006 and Meeting status OBJ-001.", definition:"Ordered sequence of states a Meeting Protocol passes through: generated -> edited (zero or more times) -> exported. Tracks how the document evolves after LLM creation.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-016", properties:{aliases:["Automatic Speech Recognition", "Распознавание речи", "Speech-to-Text", "STT"], created:date('2026-05-17'), name:"ASR", context:"Invoked inside BP-002; vendor/model TBD.", definition:"Automatic Speech Recognition — converts audio speech to written text. In Transcrib, ASR is performed by an external engine (EXT-02) that also handles speaker diarization.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-017", properties:{aliases:["Large Language Model", "Большая языковая модель", "Language Model"], created:date('2026-05-17'), name:"LLM", context:"Invoked inside BP-004 via EXT-03; specific service TBD.", definition:"Large Language Model — AI model used to summarize and structure the verbatim transcript into a formatted protocol. Receives prompt with transcript + template, returns structured Markdown.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-018", properties:{aliases:["Асинхронная задача", "Background Job"], created:date('2026-05-17'), name:"Async Job", context:"Materialized as OBJ-003 (TranscriptionJob) and OBJ-005 (ProtocolGenerationJob).", definition:"Asynchronous background task that performs a long-running operation (transcription or protocol generation) outside the synchronous request-response cycle. User polls or is notified when the job completes.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-019", properties:{aliases:["Задача транскрибации"], created:date('2026-05-17'), name:"TranscriptionJob", context:"Created in BP-001; executed in BP-002. OBJ-003.", definition:"Async job record tracking ASR + diarization for a single recording. Transitions queued -> in_progress -> completed | failed. Primary means of surfacing transcription progress and errors.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-020", properties:{aliases:["Задача генерации протокола"], created:date('2026-05-17'), name:"ProtocolGenerationJob", context:"Triggered at end of BP-002; executed in BP-004. OBJ-005.", definition:"Async job record tracking LLM-based protocol generation for a transcript. Created automatically when TranscriptionJob completes; tracks prompt template version, timing, failure details.", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:GlossaryTerm{id: row.id}) SET n += row.properties;
UNWIND [{id:"GLO-021", properties:{aliases:["Объектное хранилище", "Blob Storage", "File Storage"], created:date('2026-05-17'), name:"Object Storage", context:"Corresponds to EXT-04; used in BP-001 and BP-002; specific service TBD.", definition:"Remote binary storage service used to persist large video files. The system stores the file there and records only the storage path reference in the Recording entity.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-022", properties:{aliases:["Шаблон промпта", "LLM Prompt"], created:date('2026-05-17'), name:"Prompt Template", context:"Used in BP-004; version recorded in OBJ-005 for audit. Format/versioning mechanism TBD.", definition:"Versioned template defining the structure and instructions given to the LLM when generating a protocol from a transcript. Controls which sections (participants, topics, decisions, action items) the LLM must produce and in what format.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-023", properties:{aliases:["Маркдаун"], created:date('2026-05-17'), name:"Markdown", context:"Stored in OBJ-006.markdown_content; edited in BP-005; exported in BP-006.", definition:"Lightweight text markup language used as the internal storage format for meeting protocols. The user edits the protocol as Markdown; also the source format for PDF export.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-024", properties:{aliases:["Экспорт в PDF", "Export to PDF"], created:date('2026-05-17'), name:"PDF Export", context:"BP-006; triggered by the Author.", definition:"On-demand conversion of a Markdown protocol to a PDF file delivered as a browser download. The PDF is transient — not persisted after delivery.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-025", properties:{aliases:["Загрузка", "File Upload"], created:date('2026-05-17'), name:"Upload", context:"First user action; corresponds to BP-001.", definition:"User action of submitting a video file to the system via the web interface. Initiates meeting record creation and queues the transcription pipeline. Files up to 300-500 MB must be supported.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-026", properties:{aliases:["Подсказка языка", "Source Language", "Language Setting"], created:date('2026-05-17'), name:"Language Hint", context:"Stored as Meeting.language (OBJ-001-A03); supplied during BP-001; passed to ASR in BP-002. Supported language set + auto-detect accuracy TBD.", definition:"Optional user-supplied indication of the primary spoken language (RU, EN, or auto-detect). The ASR engine uses this hint to improve transcription accuracy.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-027", properties:{aliases:["Пользователь", "Meeting Participant", "Участник встречи"], created:date('2026-05-17'), name:"User", context:"External user entity (EXT-01) interacting with the system. Plays role ROL-01 Author at MVP.", definition:"The human person who interacts with the Transcrib UI: uploads recordings, reviews transcripts, edits and exports protocols. At MVP, the User is identical to the Author role; the distinction matters only when authentication and multi-user sharing are introduced.", updated:date('2026-05-17'), status:"draft"}}, {id:"GLO-028", properties:{assumption_note:"Resolution method (heuristic or LLM-based) and confidence threshold are TBD at SA phase.", aliases:["Идентификация спикеров", "Сопоставление имён", "Name Attribution"], created:date('2026-05-17'), name:"Speaker Name Resolution", context:"Performed inside BP-002 at step BP-002-S07B; results stored in Transcript.speaker_map (OBJ-004-A08). Improves readability of both Transcript and Protocol.", definition:"Post-diarization step that substitutes anonymous speaker labels (Speaker 1, Speaker 2, ...) with real participant names when those names are mentioned in the transcript itself (self-introductions, addressed names). Unresolved labels remain as Speaker N.", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:GlossaryTerm{id: row.id}) SET n += row.properties;
UNWIND [{id:"STK-01", properties:{role:"Primary User", interest:"Uploads meeting video recordings and receives verbatim transcripts and structured meeting protocols for archiving, reporting, or task tracking", name:"Meeting Participant"}}, {id:"STK-02", properties:{assumption_note:"Inferred as natural consumer of protocol artifact. In MVP scope may be same person as STK-01.", role:"Secondary Stakeholder (assumption)", interest:"Interested in the meeting protocol artifact for distributing decisions and action items", name:"Meeting Organizer", status:"assumption"}}] AS row
CREATE (n:Stakeholder{id: row.id}) SET n += row.properties;
UNWIND [{id:"EXT-01", properties:{name:"Meeting Participant", description:"The human user who interacts with the system UI: uploads the meeting video file and downloads the resulting verbatim transcript and meeting protocol", type:"User"}}, {id:"EXT-02", properties:{assumption_note:"Dedicated ASR+diarization engine required for speaker-attributed timestamped transcripts. Cloud API or self-hosted. Stack TBD.", name:"ASR / Diarization Engine", description:"External ASR and speaker diarization service. Receives audio, returns speaker-attributed transcript segments with timestamps. Vendor/model TBD.", type:"ExternalSystem", status:"assumption"}}, {id:"EXT-03", properties:{assumption_note:"LLM is the natural tool to transform raw transcript into structured protocol. Provider TBD.", name:"LLM Protocol Generator", description:"LLM service that converts the verbatim transcript into a structured meeting protocol (participants, topics, decisions, action items). Provider/model TBD.", type:"ExternalSystem", status:"assumption"}}, {id:"EXT-04", properties:{assumption_note:"Large file sizes imply dedicated storage layer for durability across async steps. S3/local FS/similar. Stack TBD.", name:"File / Object Storage", description:"Object storage that holds uploaded video files during async processing. Required because 300-500 MB files cannot be held in memory through the pipeline.", type:"ExternalSystem", status:"assumption"}}] AS row
CREATE (n:ExternalEntity{id: row.id}) SET n += row.properties;
UNWIND [{_id:288, properties:{field_category:"input", name:"title", id:"FORM-MeetingCatalog-F01", label:"Title", field_type:"text", updated:datetime('2026-05-18T07:04:51.208Z'), required:false, order:1}}, {_id:289, properties:{field_category:"input", name:"status", label:"Status", id:"FORM-MeetingCatalog-F02", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"select", required:true, order:2}}, {_id:290, properties:{field_category:"input", name:"language", label:"Language", id:"FORM-MeetingCatalog-F03", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"select", required:false, order:3}}, {_id:291, properties:{field_category:"input", name:"uploaded_at", label:"Uploaded", id:"FORM-MeetingCatalog-F04", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"datetime", required:true, order:4}}, {_id:292, properties:{field_category:"input", name:"duration_sec", label:"Duration", id:"FORM-MeetingCatalog-F05", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"number", required:false, order:5}}, {_id:293, properties:{field_category:"action", name:"open_button", id:"FORM-MeetingCatalog-F06", label:"Open", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"button", required:false, order:6}}, {_id:294, properties:{field_category:"input", name:"title", id:"FORM-MeetingDetail-F01", label:"Title", field_type:"text", updated:datetime('2026-05-18T07:04:51.208Z'), required:false, order:1}}, {_id:295, properties:{field_category:"input", name:"language", label:"Language", id:"FORM-MeetingDetail-F02", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"select", required:false, order:2}}, {_id:296, properties:{field_category:"input", name:"status", label:"Status", id:"FORM-MeetingDetail-F03", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"select", required:true, order:3}}, {_id:297, properties:{field_category:"input", name:"uploaded_at", label:"Uploaded at", id:"FORM-MeetingDetail-F04", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"datetime", required:true, order:4}}, {_id:298, properties:{field_category:"input", name:"updated_at", label:"Last update", id:"FORM-MeetingDetail-F05", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"datetime", required:true, order:5}}, {_id:299, properties:{field_category:"input", name:"filename", id:"FORM-MeetingDetail-F06", label:"File name", field_type:"text", updated:datetime('2026-05-18T07:04:51.208Z'), required:true, order:6}}, {_id:300, properties:{field_category:"input", name:"size_bytes", id:"FORM-MeetingDetail-F07", label:"Size", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"number", required:true, order:7}}, {_id:301, properties:{field_category:"input", name:"mime_type", label:"Format", id:"FORM-MeetingDetail-F08", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"select", required:true, order:8}}, {_id:302, properties:{field_category:"input", name:"duration_sec", label:"Duration", id:"FORM-MeetingDetail-F09", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"number", required:false, order:9}}, {_id:303, properties:{field_category:"input", name:"error_reason", label:"Error", id:"FORM-MeetingDetail-F10", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"textarea", required:false, order:10}}, {_id:304, properties:{field_category:"action", name:"delete_button", label:"Delete meeting", id:"FORM-MeetingDetail-F11", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"button", required:false, order:11}}, {_id:305, properties:{field_category:"display", name:"header", label:"Delete this meeting?", id:"FORM-MeetingDeleteConfirm-F01", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"header", required:false, order:1}}, {_id:306, properties:{field_category:"input", name:"title", id:"FORM-MeetingDeleteConfirm-F02", label:"Meeting title", field_type:"text", updated:datetime('2026-05-18T07:04:51.208Z'), required:false, order:2}}, {_id:307, properties:{field_category:"action", name:"confirm_button", label:"Confirm delete", id:"FORM-MeetingDeleteConfirm-F03", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"button", required:false, order:3}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:FormField;
UNWIND [{_id:308, properties:{field_category:"action", name:"cancel_button", label:"Cancel", id:"FORM-MeetingDeleteConfirm-F04", updated:datetime('2026-05-18T07:04:51.208Z'), field_type:"button", required:false, order:4}}, {_id:326, properties:{field_category:"display", name:"header", label:"Upload meeting video", id:"FORM-MeetingUpload-F01", updated:datetime('2026-05-18T07:06:40.999Z'), field_type:"header", required:false, order:1}}, {_id:327, properties:{field_category:"input", name:"file", id:"FORM-MeetingUpload-F02", label:"Video file (MP4 / MKV / MOV, max 500 MB)", field_type:"file", updated:datetime('2026-05-18T07:06:40.999Z'), required:true, order:2}}, {_id:328, properties:{field_category:"input", name:"language", id:"FORM-MeetingUpload-F03", label:"Language (leave blank for auto-detect)", updated:datetime('2026-05-18T07:06:40.999Z'), field_type:"select", required:false, order:3}}, {_id:329, properties:{field_category:"input", name:"title", id:"FORM-MeetingUpload-F04", label:"Meeting title (defaults to filename)", field_type:"text", updated:datetime('2026-05-18T07:06:40.999Z'), required:false, order:4}}, {_id:330, properties:{field_category:"action", name:"submit_button", label:"Upload", id:"FORM-MeetingUpload-F05", updated:datetime('2026-05-18T07:06:40.999Z'), field_type:"button", required:false, order:5}}, {_id:331, properties:{field_category:"action", name:"cancel_button", label:"Cancel", id:"FORM-MeetingUpload-F06", updated:datetime('2026-05-18T07:06:40.999Z'), field_type:"button", required:false, order:6}}, {_id:354, properties:{field_category:"display", name:"header", label:"Transcript", id:"FORM-TranscriptView-F01", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"header", required:false, order:1}}, {_id:355, properties:{field_category:"input", name:"language", label:"Language", id:"FORM-TranscriptView-F02", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"select", required:true, order:2}}, {_id:356, properties:{field_category:"input", name:"segments_count", label:"Segments", id:"FORM-TranscriptView-F03", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"number", required:true, order:3}}, {_id:357, properties:{field_category:"input", name:"speakers_count", label:"Speakers", id:"FORM-TranscriptView-F04", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"number", required:true, order:4}}, {_id:358, properties:{field_category:"input", name:"created_at", label:"Created", id:"FORM-TranscriptView-F05", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"datetime", required:true, order:5}}, {_id:359, properties:{field_category:"input", name:"full_text", label:"Transcript content", id:"FORM-TranscriptView-F06", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"textarea", required:true, order:6}}, {_id:360, properties:{field_category:"input", name:"speaker_map", label:"Speaker name map", id:"FORM-TranscriptView-F07", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"textarea", required:false, order:7}}, {_id:361, properties:{field_category:"action", name:"download_button", label:"Download as text", id:"FORM-TranscriptView-F08", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"button", required:false, order:8}}, {_id:362, properties:{field_category:"action", name:"back_button", label:"Back to meeting", id:"FORM-TranscriptView-F09", updated:datetime('2026-05-18T07:07:50.001Z'), field_type:"button", required:false, order:9}}, {_id:393, properties:{field_category:"display", name:"header", label:"Protocol editor", id:"FORM-ProtocolEditor-F01", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"header", required:false, order:1}}, {_id:394, properties:{field_category:"input", name:"markdown_content", label:"Protocol (Markdown)", id:"FORM-ProtocolEditor-F02", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"textarea", required:true, order:2}}, {_id:395, properties:{field_category:"input", name:"version", label:"Version", id:"FORM-ProtocolEditor-F03", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"number", required:true, order:3}}, {_id:396, properties:{field_category:"input", name:"edit_count", label:"Edits", id:"FORM-ProtocolEditor-F04", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"number", required:true, order:4}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:FormField;
UNWIND [{_id:397, properties:{field_category:"input", name:"last_edited_at", label:"Last edited", id:"FORM-ProtocolEditor-F05", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"datetime", required:false, order:5}}, {_id:398, properties:{field_category:"input", name:"generated_at", label:"Generated", id:"FORM-ProtocolEditor-F06", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"datetime", required:true, order:6}}, {_id:399, properties:{field_category:"action", name:"save_button", id:"FORM-ProtocolEditor-F07", label:"Save", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"button", required:false, order:7}}, {_id:400, properties:{field_category:"action", name:"export_pdf_button", label:"Export PDF", id:"FORM-ProtocolEditor-F08", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"button", required:false, order:8}}, {_id:401, properties:{field_category:"action", name:"back_button", label:"Back to meeting", id:"FORM-ProtocolEditor-F09", updated:datetime('2026-05-18T07:09:31.14Z'), field_type:"button", required:false, order:9}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:FormField;
UNWIND [{_id:415, properties:{component_type:"layout", name:"FormLayout", description:"Standard form/page shell: header slot, body slot, action-bar slot. Applies the global spacing and accessibility patterns to every screen.", id:"CMP-FormLayout", updated:datetime('2026-05-18T07:13:40.556Z'), props:"header, body, actionBar, isLoading, errorBanner"}}, {_id:416, properties:{component_type:"display", name:"StatusBadge", description:"Compact badge that renders a MeetingStatus enum value with status-specific color/icon. Used in both catalog rows and detail headers.", id:"CMP-StatusBadge", updated:datetime('2026-05-18T07:13:40.556Z'), props:"status, size, withIcon"}}, {_id:417, properties:{component_type:"input", name:"LanguageSelect", description:"Bilingual (RU/EN) selector with a 'blank = auto-detect' option. Renders as a select on input forms and as a read-only badge on display forms (controlled by isReadOnly prop).", id:"CMP-LanguageSelect", updated:datetime('2026-05-18T07:13:40.556Z'), props:"value, isReadOnly, allowBlank, onChange"}}, {_id:418, properties:{component_type:"display", name:"DurationFormat", description:"Formats a duration in seconds as a human-readable string (e.g., 4523 -> '1h 15m 23s'). Returns a placeholder when value is null (duration not yet extracted).", id:"CMP-DurationFormat", updated:datetime('2026-05-18T07:13:40.556Z'), props:"seconds, placeholder, abbreviated"}}, {_id:419, properties:{component_type:"feedback", name:"ConfirmDialog", description:"Modal confirmation dialog with title, body, destructive/primary action variants. Used for meeting deletion (UC-003) and unsaved-changes warning in the protocol editor (UC-301 AS08).", id:"CMP-ConfirmDialog", updated:datetime('2026-05-18T07:13:40.556Z'), props:"open, title, body, confirmLabel, cancelLabel, variant, onConfirm, onCancel"}}, {_id:420, properties:{component_type:"navigation", route:"/", menu_order:1, roles:"AUTHOR", name:"NavMeetingCatalog", in_menu:true, description:"Top-level route 'Meetings' (catalog). Default landing page for AUTHOR.", id:"CMP-NavMeetingCatalog", updated:datetime('2026-05-18T07:13:54.78Z')}}, {_id:421, properties:{component_type:"navigation", menu_order:2, route:"/upload", roles:"AUTHOR", name:"NavMeetingUpload", in_menu:true, description:"Top-level route 'Upload'. AUTHOR uploads a new meeting video.", id:"CMP-NavMeetingUpload", updated:datetime('2026-05-18T07:13:54.78Z')}}, {_id:422, properties:{component_type:"navigation", route:"/meetings/:id", roles:"AUTHOR", name:"NavMeetingDetail", in_menu:false, description:"Meeting detail route. Reached by clicking a row in the catalog. Not a top-level menu item.", parent_menu:"CMP-NavMeetingCatalog", id:"CMP-NavMeetingDetail", updated:datetime('2026-05-18T07:13:54.78Z')}}, {_id:423, properties:{component_type:"navigation", route:"/meetings/:id/delete", roles:"AUTHOR", name:"NavMeetingDeleteConfirm", in_menu:false, description:"Delete-confirmation route (also rendered as modal overlay over the detail page). Not a menu item.", parent_menu:"CMP-NavMeetingDetail", id:"CMP-NavMeetingDeleteConfirm", updated:datetime('2026-05-18T07:13:54.78Z')}}, {_id:424, properties:{component_type:"navigation", route:"/meetings/:id/transcript", roles:"AUTHOR", name:"NavTranscriptView", in_menu:false, description:"Transcript view route. Reached via 'View transcript' link from meeting detail (gated by Meeting.status >= TRANSCRIPT_READY).", parent_menu:"CMP-NavMeetingDetail", id:"CMP-NavTranscriptView", updated:datetime('2026-05-18T07:13:54.78Z')}}, {_id:425, properties:{component_type:"navigation", route:"/meetings/:id/protocol", roles:"AUTHOR", name:"NavProtocolEditor", in_menu:false, description:"Protocol editor route. Reached via 'Review/Edit protocol' link from meeting detail (gated by Meeting.status in {PROTOCOL_READY, EDITED}).", parent_menu:"CMP-NavMeetingDetail", id:"CMP-NavProtocolEditor", updated:datetime('2026-05-18T07:13:54.78Z')}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:Component;
UNWIND [{_id:204, properties:{description:"File upload to object storage is in progress.", label:"Uploading", id:"ENUM-MeetingStatus-V01", value:"UPLOADING", order:1}}, {_id:205, properties:{description:"Transcription job is queued or running (ASR + diarization).", label:"Transcribing", id:"ENUM-MeetingStatus-V02", value:"TRANSCRIBING", order:2}}, {_id:206, properties:{description:"Transcript persisted; protocol generation has not started yet (or is in progress).", label:"Transcript ready", id:"ENUM-MeetingStatus-V03", value:"TRANSCRIPT_READY", order:3}}, {_id:207, properties:{description:"LLM-based protocol generation job is queued or running.", label:"Generating protocol", id:"ENUM-MeetingStatus-V04", value:"PROTOCOL_GENERATING", order:4}}, {_id:208, properties:{description:"Protocol has been generated and persisted; no manual edits yet.", label:"Protocol ready", id:"ENUM-MeetingStatus-V05", value:"PROTOCOL_READY", order:5}}, {_id:209, properties:{description:"Protocol has been manually edited at least once. Repeats on every save (version increments).", label:"Edited", id:"ENUM-MeetingStatus-V06", value:"EDITED", order:6}}, {_id:210, properties:{description:"Non-recoverable error in the transcription or protocol-generation pipeline. Terminal state per BRQ-009.", label:"Failed", id:"ENUM-MeetingStatus-V07", value:"FAILED", order:7}}, {_id:212, properties:{description:"Russian language. Used for ASR language hint and LLM prompt selection.", label:"Russian", id:"ENUM-MeetingLanguage-V01", value:"RU", order:1}}, {_id:213, properties:{description:"English language. Used for ASR language hint and LLM prompt selection.", label:"English", id:"ENUM-MeetingLanguage-V02", value:"EN", order:2}}, {_id:223, properties:{description:"MPEG-4 container.", id:"ENUM-VideoMimeType-V01", label:"MP4", value:"video/mp4", order:1}}, {_id:224, properties:{description:"Matroska container.", id:"ENUM-VideoMimeType-V02", label:"MKV", value:"video/x-matroska", order:2}}, {_id:225, properties:{description:"QuickTime / MOV container.", id:"ENUM-VideoMimeType-V03", label:"MOV", value:"video/quicktime", order:3}}, {_id:242, properties:{description:"Job created, waiting for a worker.", label:"Queued", id:"ENUM-JobStatus-V01", value:"QUEUED", order:1}}, {_id:243, properties:{description:"Worker is running the job.", label:"In progress", id:"ENUM-JobStatus-V02", value:"IN_PROGRESS", order:2}}, {_id:244, properties:{description:"Job finished successfully and the produced artifact has been persisted. Terminal.", label:"Completed", id:"ENUM-JobStatus-V03", value:"COMPLETED", order:3}}, {_id:245, properties:{description:"Job terminated with a non-recoverable error. error_reason MUST be set (BRQ-010). Terminal.", label:"Failed", id:"ENUM-JobStatus-V04", value:"FAILED", order:4}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:EnumValue;
UNWIND [{id:"BRQ-001", properties:{severity:"hard", created:date('2026-05-17'), name:"File size limit", statement:"Recording.size_bytes MUST be <= 524288000 bytes (500 MB). Uploads exceeding the threshold are rejected before storage.", classification:"constraint", updated:date('2026-05-17'), rationale:"Prevents runaway storage costs and ASR queue saturation from very large files at MVP scale.", status:"draft"}}, {id:"BRQ-002", properties:{severity:"hard", created:date('2026-05-17'), name:"Allowed file formats", statement:"Recording.mime_type MUST be one of {video/mp4, video/x-matroska, video/quicktime} (MP4, MKV, MOV). Other types are rejected.", classification:"constraint", updated:date('2026-05-17'), rationale:"ASR pipeline supports audio extraction only from these container formats; accepting others causes silent failures.", status:"draft"}}, {id:"BRQ-003", properties:{severity:"hard", assumption_note:"Validation method TBD (FFprobe header check or short-duration probe). Full frame-level integrity not guaranteed at MVP.", created:date('2026-05-17'), statement:"The uploaded file MUST be a valid, non-corrupt video container from which audio can be extracted. Corrupt or unplayable files are rejected during upload acceptance.", name:"File integrity", classification:"constraint", updated:date('2026-05-17'), rationale:"Corrupt files cause opaque failures deep in the ASR pipeline; early validation gives a clearer user-facing error.", status:"draft"}}, {id:"BRQ-004", properties:{severity:"hard", created:date('2026-05-17'), name:"Supported languages", statement:"Meeting.language MUST be one of {ru, en, auto}. Other values are rejected at upload.", classification:"constraint", updated:date('2026-05-17'), rationale:"MVP supports RU and EN only; auto-detect delegated to ASR. Broader languages out of scope.", status:"draft"}}, {id:"BRQ-005", properties:{severity:"hard", created:date('2026-05-17'), name:"Auto-detect language fallback", statement:"If Meeting.language = auto, the ASR engine MUST detect the language and the detected value is recorded as Transcript.language. The Meeting.language record stays as auto.", classification:"derivation", updated:date('2026-05-17'), rationale:"Auto-detection should not silently overwrite user input; Transcript.language records ground truth.", status:"draft"}}, {id:"BRQ-006", properties:{severity:"hard", created:date('2026-05-17'), name:"One TranscriptionJob per Recording", statement:"For each Recording there MUST be exactly one TranscriptionJob (1:1 relationship). Re-transcription is treated as a new Recording or explicit reprocess (out of MVP scope).", classification:"invariant", updated:date('2026-05-17'), rationale:"Simplifies status tracking and avoids divergent transcripts.", status:"draft"}}, {id:"BRQ-007", properties:{severity:"hard", created:date('2026-05-17'), name:"Auto-trigger protocol generation", statement:"When TranscriptionJob.status transitions to completed, a ProtocolGenerationJob MUST be created automatically for the resulting Transcript.", classification:"workflow", updated:date('2026-05-17'), rationale:"User does not need to manually initiate protocol generation; this is part of the end-to-end pipeline.", status:"draft"}}, {id:"BRQ-008", properties:{severity:"hard", created:date('2026-05-17'), name:"Meeting status mirrors pipeline", statement:"Meeting.status MUST reflect the current pipeline stage and follow the allowed lifecycle (uploading -> transcribing -> transcript_ready -> protocol_generating -> protocol_ready -> edited | failed).", classification:"invariant", updated:date('2026-05-17'), rationale:"The Meeting is the single authoritative status surface for the user; jobs carry internal status separately.", status:"draft"}}, {id:"BRQ-009", properties:{severity:"hard", created:date('2026-05-17'), name:"Job terminal states are immutable", statement:"Once TranscriptionJob.status or ProtocolGenerationJob.status reaches {completed, failed}, it MUST NOT change.", classification:"invariant", updated:date('2026-05-17'), rationale:"Terminal states are an audit anchor; mutating them would invalidate downstream artifacts and event records.", status:"draft"}}, {id:"BRQ-010", properties:{severity:"hard", created:date('2026-05-17'), name:"Failure recorded with reason", statement:"If a job status is failed, error_reason MUST be non-null and human-readable so the UI can surface it to the user.", classification:"invariant", updated:date('2026-05-17'), rationale:"Silent failures degrade trust and make support diagnostics impossible.", status:"draft"}}, {id:"BRQ-011", properties:{severity:"hard", created:date('2026-05-17'), name:"Required protocol sections", statement:"A persisted Protocol MUST contain all four sections: Participants, Discussion Topics, Decisions, Action Items.", classification:"constraint", updated:date('2026-05-17'), rationale:"These four sections are the value the system promises to deliver. Missing sections route generation to the failure branch.", status:"draft"}}, {id:"BRQ-012", properties:{severity:"soft", assumption_note:"No automated post-generation completeness check at MVP; user reviews/corrects in BP-005.", created:date('2026-05-17'), statement:"Action items in the protocol SHOULD include an assignee and a deadline when these are stated in the meeting; best-effort extraction by the LLM.", name:"Action items have assignee and deadline when extractable", classification:"constraint", updated:date('2026-05-17'), rationale:"Captures the value of action items; soft because LLM extraction quality is inherently variable.", status:"draft"}}, {id:"BRQ-013", properties:{severity:"hard", created:date('2026-05-17'), name:"Protocol language matches transcript", statement:"Protocol MUST be generated in the same language as Transcript.language. The LLM is prompted to produce output in the source language.", classification:"constraint", updated:date('2026-05-17'), rationale:"User expects the protocol to be readable in the same language as the meeting.", status:"draft"}}, {id:"BRQ-014", properties:{severity:"hard", created:date('2026-05-17'), name:"Protocol version increments on save", statement:"Protocol.version MUST increment by 1 each time the user saves an edit in BP-005.", classification:"invariant", updated:date('2026-05-17'), rationale:"Versioning enables future audit/undo and is a low-cost defense against silent overwrites.", status:"draft"}}, {id:"BRQ-015", properties:{severity:"hard", created:date('2026-05-17'), name:"Edit count tracks saves", statement:"Protocol.edit_count MUST equal the number of manual saves performed since initial generation.", classification:"invariant", updated:date('2026-05-17'), rationale:"Surfaces how many times the protocol was changed by the user.", status:"draft"}}, {id:"BRQ-016", properties:{severity:"hard", assumption_note:"No real authentication or access check exists at MVP; rule recorded for forward design only.", created:date('2026-05-17'), statement:"The Author (ROL-01) of a Meeting is the sole owner of OBJ-002 Recording, OBJ-004 Transcript, and OBJ-006 Protocol for that Meeting.", name:"Author owns derived artifacts", classification:"authorization", updated:date('2026-05-17'), rationale:"Establishes the ownership model that future auth will enforce.", status:"draft"}}, {id:"BRQ-017", properties:{severity:"hard", created:date('2026-05-17'), name:"PDF export is transient", statement:"PDF export output is delivered to the user as a download; the system MUST NOT persist the rendered PDF.", classification:"invariant", updated:date('2026-05-17'), rationale:"Markdown is the canonical form; persisting PDFs creates stale-copy hazards and storage bloat.", status:"draft"}}, {id:"BRQ-018", properties:{severity:"hard", created:date('2026-05-17'), name:"Markdown is canonical", statement:"All edits and exports MUST operate on the canonical Markdown stored in Protocol.markdown_content. PDF and any rendered views are derivations.", classification:"invariant", updated:date('2026-05-17'), rationale:"Single source of truth simplifies the data model and prevents divergence between formats.", status:"draft"}}, {id:"BRQ-019", properties:{severity:"soft", created:date('2026-05-17'), name:"No processing-time SLA", statement:"There is NO maximum processing time for transcription or protocol generation. Users receive completion via status updates, not deadline guarantees.", classification:"constraint", updated:date('2026-05-17'), rationale:"Tech stack TBD; an SLA cannot be guaranteed at MVP. UX surfaces async status instead.", status:"draft"}}, {id:"BRQ-020", properties:{severity:"hard", assumption_note:"Retention duration beyond pipeline completion is TBD pending storage cost analysis; indefinite retention assumed at MVP.", created:date('2026-05-17'), statement:"The original video file in object storage MUST be retained at least until both Transcript and Protocol have been produced.", name:"Recording retention until artifacts produced", classification:"constraint", updated:date('2026-05-17'), rationale:"Pipeline failures may require re-running stages from the source file.", status:"draft"}}] AS row
CREATE (n:BusinessRule{id: row.id}) SET n += row.properties;
UNWIND [{id:"BRQ-021", properties:{severity:"soft", assumption_note:"Resolution method TBD (heuristic vs. LLM pass). Confidence threshold for substitution TBD. At MVP only the in-dialogue context is used; no external participant list lookup.", created:date('2026-05-17'), statement:"After diarization assigns anonymous speaker labels (Speaker 1, Speaker 2, ...), the system MUST attempt to resolve each label to a real name by analyzing self-introductions and addressed names within the transcript. When a confident association is found, the label is substituted with the resolved name across the transcript and recorded in Transcript.speaker_map. Labels without a confident match remain as Speaker N.", name:"Speaker name resolution from dialogue context", classification:"derivation", updated:date('2026-05-17'), rationale:"Speaker labels are anonymous by default; resolving names where mentioned makes the transcript and protocol substantially more readable. Soft because resolution accuracy depends on dialogue content and the chosen resolution method.", status:"draft"}}] AS row
CREATE (n:BusinessRule{id: row.id}) SET n += row.properties;
UNWIND [{_id:168, properties:{phase:"BA->SA", summary:"BA phase complete for Transcrib. Covers 2 ProcessGroups, 6 BusinessProcesses (3 decomposed), 6 BusinessEntities, 2 Roles, 27 GlossaryTerms, 21 BusinessRules (19 hard / 2 soft). Validation L1-L8 passed. Produces 9 UC candidates and 6 SA module proposals. 3 open questions deferred to SA.", sa_modules:"[{\"module\":\"Ingestion\",\"description\":\"Upload, validation, chunked transfer, object storage write, transcription job dispatch\",\"source_bp\":[\"BP-001\"]},{\"module\":\"TranscriptionPipeline\",\"description\":\"ASR worker, audio extraction, diarization, speaker-name resolution from dialogue context, transcript persistence\",\"source_bp\":[\"BP-002\"]},{\"module\":\"ProtocolGeneration\",\"description\":\"LLM orchestration, prompt template management/versioning, response parsing, protocol persistence\",\"source_bp\":[\"BP-004\"]},{\"module\":\"ProtocolEditing\",\"description\":\"Markdown editor UI, protocol versioning, save/discard\",\"source_bp\":[\"BP-005\"]},{\"module\":\"ExportDelivery\",\"description\":\"Transcript download endpoint, PDF rendering and delivery\",\"source_bp\":[\"BP-003\",\"BP-006\"]},{\"module\":\"MeetingStatus\",\"description\":\"Cross-cutting Meeting lifecycle status aggregation and UI display (polling or push)\",\"source_bp\":[\"BP-001\",\"BP-002\",\"BP-004\"]}]", uc_candidates:"[{\"id\":\"UC-001\",\"label\":\"Upload video and create meeting\",\"source\":[\"BP-001\"]},{\"id\":\"UC-002\",\"label\":\"Transcribe audio with diarization\",\"source\":[\"BP-002 S01-S07\"]},{\"id\":\"UC-003\",\"label\":\"Resolve speaker names in transcript\",\"source\":[\"BP-002-S07B\"]},{\"id\":\"UC-004\",\"label\":\"Generate meeting protocol via LLM\",\"source\":[\"BP-004 happy path\"]},{\"id\":\"UC-005\",\"label\":\"Handle transcription and protocol failures\",\"source\":[\"BP-002-S09\",\"BP-004-S10\"]},{\"id\":\"UC-006\",\"label\":\"View and download transcript\",\"source\":[\"BP-003\"]},{\"id\":\"UC-007\",\"label\":\"Review and edit protocol in Markdown editor\",\"source\":[\"BP-005\"]},{\"id\":\"UC-008\",\"label\":\"Export protocol as PDF\",\"source\":[\"BP-006\"]},{\"id\":\"UC-009\",\"label\":\"Display meeting processing status\",\"source\":[\"cross-cutting: BP-001-S07, BP-002-S08/S09, BP-004-S09/S10\"]}]", created:date('2026-05-17'), open_questions:"[{\"id\":\"OQ-1\",\"question\":\"Speaker-name resolution sequencing: must BP-002-S07B complete before BP-004 fires, or can protocol generation start with anonymous labels and names be resolved post-hoc? Affects UC-003 timing and TranscriptionPipeline module boundary.\"},{\"id\":\"OQ-2\",\"question\":\"Failure retry strategy (BRQ-019, BP-002-S09, BP-004-S10): manual user-triggered retry vs. automatic with back-off? Determines whether UC-005 needs UI controls or is informational-only.\"},{\"id\":\"OQ-3\",\"question\":\"Protocol versioning model (BRQ-014/015): append-only immutable versions vs. in-place overwrite with single prior snapshot? Drives SA domain model for Protocol and impacts UC-007 (edit) and UC-008 (export which version?).\"},{\"id\":\"OQ-4\",\"question\":\"Tech stack still TBD (EXT-02 ASR vendor, EXT-03 LLM provider, EXT-04 storage, PDF rendering). To be decided in /nacl-sa-architect.\"}]", entity_traces:"[{\"ba\":\"OBJ-001\",\"name\":\"Meeting\",\"sa_entity\":\"Meeting\"},{\"ba\":\"OBJ-002\",\"name\":\"Recording\",\"sa_entity\":\"Recording\"},{\"ba\":\"OBJ-003\",\"name\":\"TranscriptionJob\",\"sa_entity\":\"TranscriptionJob\"},{\"ba\":\"OBJ-004\",\"name\":\"Transcript\",\"sa_entity\":\"Transcript\"},{\"ba\":\"OBJ-005\",\"name\":\"ProtocolGenerationJob\",\"sa_entity\":\"ProtocolGenerationJob\"},{\"ba\":\"OBJ-006\",\"name\":\"Protocol\",\"sa_entity\":\"Protocol\"}]", rule_req_map:"[{\"brq\":\"BRQ-001\",\"name\":\"File size limit\",\"proposed_req\":\"REQ-001\",\"category\":\"FR\"},{\"brq\":\"BRQ-002\",\"name\":\"Allowed file formats\",\"proposed_req\":\"REQ-002\",\"category\":\"FR\"},{\"brq\":\"BRQ-003\",\"name\":\"File integrity\",\"proposed_req\":\"REQ-003\",\"category\":\"FR\"},{\"brq\":\"BRQ-004\",\"name\":\"Supported languages\",\"proposed_req\":\"REQ-004\",\"category\":\"FR\"},{\"brq\":\"BRQ-005\",\"name\":\"Auto-detect language fallback\",\"proposed_req\":\"REQ-005\",\"category\":\"FR\"},{\"brq\":\"BRQ-006\",\"name\":\"One TranscriptionJob per Recording\",\"proposed_req\":\"REQ-006\",\"category\":\"FR\"},{\"brq\":\"BRQ-007\",\"name\":\"Auto-trigger protocol generation\",\"proposed_req\":\"REQ-007\",\"category\":\"FR\"},{\"brq\":\"BRQ-008\",\"name\":\"Meeting status mirrors pipeline\",\"proposed_req\":\"REQ-008\",\"category\":\"FR\"},{\"brq\":\"BRQ-009\",\"name\":\"Job terminal states are immutable\",\"proposed_req\":\"REQ-009\",\"category\":\"FR\"},{\"brq\":\"BRQ-010\",\"name\":\"Failure recorded with reason\",\"proposed_req\":\"REQ-010\",\"category\":\"FR\"},{\"brq\":\"BRQ-011\",\"name\":\"Required protocol sections\",\"proposed_req\":\"REQ-011\",\"category\":\"FR\"},{\"brq\":\"BRQ-012\",\"name\":\"Action items have assignee and deadline when extractable\",\"proposed_req\":\"REQ-012\",\"category\":\"NFR\"},{\"brq\":\"BRQ-013\",\"name\":\"Protocol language matches transcript\",\"proposed_req\":\"REQ-013\",\"category\":\"FR\"},{\"brq\":\"BRQ-014\",\"name\":\"Protocol version increments on save\",\"proposed_req\":\"REQ-014\",\"category\":\"FR\"},{\"brq\":\"BRQ-015\",\"name\":\"Edit count tracks saves\",\"proposed_req\":\"REQ-015\",\"category\":\"FR\"},{\"brq\":\"BRQ-016\",\"name\":\"Author owns derived artifacts\",\"proposed_req\":\"REQ-016\",\"category\":\"FR\"},{\"brq\":\"BRQ-017\",\"name\":\"PDF export is transient\",\"proposed_req\":\"REQ-017\",\"category\":\"FR\"},{\"brq\":\"BRQ-018\",\"name\":\"Markdown is canonical\",\"proposed_req\":\"REQ-018\",\"category\":\"FR\"},{\"brq\":\"BRQ-019\",\"name\":\"No processing-time SLA\",\"proposed_req\":\"REQ-019\",\"category\":\"NFR\"},{\"brq\":\"BRQ-020\",\"name\":\"Recording retention until artifacts produced\",\"proposed_req\":\"REQ-020\",\"category\":\"FR\"},{\"brq\":\"BRQ-021\",\"name\":\"Speaker name resolution from dialogue context\",\"proposed_req\":\"REQ-021\",\"category\":\"NFR\"}]", id:"HP-001", role_traces:"[{\"ba\":\"ROL-01\",\"name\":\"Author\",\"sa_role\":\"Author\"},{\"ba\":\"ROL-02\",\"name\":\"Reviewer\",\"sa_role\":\"Reviewer (assumption — no MVP behavior)\"}]", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:`UNIQUE IMPORT LABEL`{`UNIQUE IMPORT ID`: row._id}) SET n += row.properties SET n:HandoffPackage;
UNWIND [{id:"TECH-001", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Monorepo & tooling (pnpm workspaces, tsconfig, eslint, prettier, vitest)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-002", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Docker Compose dev stack (Postgres, Redis, MinIO)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-003", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Prisma schema & migrations (Meeting, Recording, jobs, Transcript, Protocol + enums)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-004", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Shared Zod schemas, DTOs, enums (shared/ package)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-005", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Fastify API scaffold (zod provider, error handler, Pino, /health)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-006", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"BullMQ + worker process scaffold", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-007", properties:{agent:"nacl-tl-dev", last_reco