UNWIND [{id:"ROL-01", properties:{code:"author", responsibility:"Provides a valid source recording; reviews and corrects the generated protocol to ensure accuracy before distribution.", created:date('2026-05-17'), authority:"Upload video recordings; view own transcripts and protocols; edit own protocols in the Markdown editor; export own protocols to PDF; delete own recordings and derived artifacts.", name:"Author", description:"The person who uploaded a meeting recording and owns the resulting transcript and protocol. The primary - and at MVP the only - active human role.", updated:date('2026-05-17'), status:"draft"}}, {id:"ROL-02", properties:{assumption_note:"No authentication or sharing mechanism exists at MVP. Recorded for completeness and future multi-user scope; no distinct system behavior today.", code:"reviewer", responsibility:"Validates decisions and action items from an attendee perspective.", created:date('2026-05-17'), authority:"View protocols shared with them; annotate or comment on protocol content (future).", name:"Reviewer", description:"A meeting participant (typically the organizer, STK-02) who reads/annotates a protocol produced by another person. No technical distinction from Author at MVP.", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:BusinessRole{id: row.id}) SET n += row.properties;
UNWIND [{id:"SR-01", properties:{system_only:false, responsibilities:"Upload meeting recordings; observe pipeline progress; view/download transcripts; review and edit generated protocols; export protocols to PDF; delete own meetings and derived artifacts.", created:datetime('2026-05-18T06:53:14.885Z'), name:"AUTHOR", description:"The end-user who uploads a meeting recording and owns the derived artifacts (Recording, Transcript, Protocol). The sole active human role at MVP. Merges BA roles ROL-01 Author and ROL-02 Reviewer (the Reviewer has no distinct behavior at MVP per BA assumption).", type:"internal", updated:datetime('2026-05-18T06:53:14.885Z'), status:"draft"}}, {id:"SR-02", properties:{system_only:true, responsibilities:"Run TranscriptionJob workflow (ASR + diarization); auto-create ProtocolGenerationJob on transcript completion; run LLM protocol generation; persist Transcript and Protocol artifacts; update Meeting.status as the pipeline progresses; record error_reason on failures.", created:datetime('2026-05-18T06:53:14.885Z'), name:"SYSTEM", description:"Infrastructure role representing automated background workers and async pipeline machinery. Owns job lifecycles (transcription, protocol generation), auto-triggers downstream jobs per BRQ-007, and writes Meeting.status updates per BRQ-008. No BA mapping; not user-facing.", type:"internal", updated:datetime('2026-05-18T06:53:14.885Z'), status:"draft"}}] AS row
CREATE (n:SystemRole{id: row.id}) SET n += row.properties;
UNWIND [{id:"BP-001-S01", properties:{actor:"STK-01", step_order:1, created:date('2026-05-17'), name:"Open Upload Page", description:"User navigates to the upload section. System renders the file upload form with format hints and size constraints visible.", stereotype:"manual", updated:date('2026-05-17'), status:"draft"}}, {id:"BP-001-S02", properties:{actor:"STK-01", assumption_note:"Language selection optional at upload; auto-detect by ASR engine if omitted.", step_order:2, created:date('2026-05-17'), name:"Select File and Language Hint", description:"User picks a video file and optionally selects a language hint (RU or EN). If omitted, auto-detection is applied in BP-002.", artifact_name:"VideoFile", stereotype:"manual", updated:date('2026-05-17'), artifact_kind:"file", status:"draft"}}, {id:"BP-001-S03", properties:{actor:"System", step_order:3, created:date('2026-05-17'), name:"Validate File", description:"System checks file format (MP4/MKV/MOV) and size (max 500 MB). On failure, user gets inline error and may retry.", artifact_name:"VideoFile", stereotype:"decision", updated:date('2026-05-17'), artifact_kind:"file", status:"draft"}}, {id:"BP-001-S03-REJ", properties:{actor:"System", created:date('2026-05-17'), name:"Show Validation Error", description:"System displays inline error (unsupported format or size). User remains on upload page and may retry with a different file.", stereotype:"automated", updated:date('2026-05-17'), status:"draft"}}, {id:"BP-001-S04", properties:{actor:"System", step_order:4, created:date('2026-05-17'), name:"Upload File in Chunks to Object Storage", description:"System transfers the validated video file to object storage (EXT-04) via chunked/multipart upload. Progress shown to user.", artifact_name:"VideoFile", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"file", status:"draft"}}, {id:"BP-001-S05", properties:{actor:"System", step_order:5, created:date('2026-05-17'), name:"Create Recording and UploadJob Records", description:"System persists a Recording entity (file metadata, storage path, language hint) and an UploadJob record, linking them.", artifact_name:"Recording", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"entity", status:"draft"}}, {id:"BP-001-S06", properties:{actor:"System", step_order:6, created:date('2026-05-17'), name:"Enqueue Transcription Job", description:"System pushes a TranscriptionJob message to the async queue, referencing the Recording. Triggers BP-002.", artifact_name:"TranscriptionJob", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"message", status:"draft"}}, {id:"BP-001-S07", properties:{actor:"System", step_order:7, created:date('2026-05-17'), name:"Show Upload Confirmation", description:"System shows \"Upload complete, transcription is processing\" with a link to the recording detail page.", stereotype:"automated", updated:date('2026-05-17'), status:"draft"}}, {id:"BP-002-S01", properties:{actor:"System (transcription worker)", step_order:1, created:date('2026-05-17'), name:"Dequeue transcription job", description:"Transcription worker polls the async job queue and dequeues the next pending job, extracting job ID, file reference, and language hint.", artifact_name:"TranscriptionJob", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"entity", status:"draft"}}, {id:"BP-002-S02", properties:{actor:"EXT-04 (Object Storage)", step_order:2, created:date('2026-05-17'), name:"Fetch video file from object storage", description:"Worker retrieves the raw video file from object storage (EXT-04) using the stored file reference. Streamed or downloaded to a working location.", artifact_name:"VideoFile", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"file", status:"draft"}}, {id:"BP-002-S03", properties:{actor:"System (transcription worker)", assumption_note:"Audio demux is an internal sub-step with no business decision; not modelled as a separate BP.", step_order:3, created:date('2026-05-17'), name:"Extract audio stream from video", description:"Worker demuxes the video container to extract the raw audio stream. Re-encoding only if ASR mandates a specific codec/sample rate.", artifact_name:"AudioStream", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"file", status:"draft"}}, {id:"BP-002-S04", properties:{actor:"EXT-02 (ASR/Diarization Engine)", assumption_note:"Language hint passed per-job; auto-detect if unset. ASR supports RU and EN at minimum.", step_order:4, created:date('2026-05-17'), name:"Submit audio to ASR/diarization engine", description:"Worker submits audio to EXT-02 with a language hint (RU/EN) or auto-detect flag.", artifact_name:"ASRRequest", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"message", status:"draft"}}, {id:"BP-002-S05", properties:{actor:"System (transcription worker)", step_order:5, created:date('2026-05-17'), name:"ASR result: success or failure?", description:"Worker evaluates EXT-02 response. Success: speaker-attributed segments. Failure: timeout, engine error, or empty result -> failure branch.", artifact_name:"ASRResponse", stereotype:"decision", updated:date('2026-05-17'), artifact_kind:"message", status:"draft"}}, {id:"BP-002-S06", properties:{actor:"EXT-02 (ASR/Diarization Engine)", step_order:6, created:date('2026-05-17'), name:"Receive speaker-attributed transcript segments", description:"Worker receives structured response from EXT-02 with speaker labels, start/end timestamps, and verbatim text per segment.", artifact_name:"TranscriptSegments", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"entity", status:"draft"}}, {id:"BP-002-S07", properties:{actor:"System (transcription worker)", step_order:7, created:date('2026-05-17'), name:"Assemble and persist full transcript", description:"Worker merges segments into a full ordered speaker-attributed transcript and persists it, linked to the originating job and meeting record.", artifact_name:"Transcript", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"entity", status:"draft"}}, {id:"BP-002-S08", properties:{actor:"System (transcription worker)", step_order:9, created:date('2026-05-17'), name:"Update job status to transcript ready", description:"Worker marks the transcription job completed with status transcript ready and emits/queues a protocol-generation job, triggering BP-004.", artifact_name:"JobStatusUpdate", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"event", status:"draft"}}, {id:"BP-002-S09", properties:{actor:"System (transcription worker)", assumption_note:"Failure notification at MVP is a UI status flag; push/email is out of scope. Retry logic TBD with tech stack.", step_order:10, created:date('2026-05-17'), name:"Mark job failed and surface error", description:"Worker marks job failed, records the error reason, and updates status so the UI can surface the failure state.", artifact_name:"JobStatusUpdate", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"event", status:"draft"}}, {id:"BP-004-S01", properties:{actor:"System", step_order:1, created:date('2026-05-17'), name:"Receive Transcript-Ready Event", description:"Protocol worker triggered by transcript-ready event emitted when BP-002 completes. Event carries meeting ID.", artifact_name:"TranscriptReadyEvent", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"event", status:"draft"}}, {id:"BP-004-S02", properties:{actor:"System", step_order:2, created:date('2026-05-17'), name:"Load Transcript", description:"Worker retrieves the verbatim speaker-attributed transcript by meeting ID.", artifact_name:"Transcript", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"data", status:"draft"}}, {id:"BP-004-S03", properties:{actor:"System", assumption_note:"Prompt template storage and versioning TBD (config/file/DB). Language detection: heuristic or ASR metadata.", step_order:3, created:date('2026-05-17'), name:"Select Prompt Template by Language", description:"Worker detects source language (RU/EN) and loads the matching structured-extraction prompt template. Prompt instructs LLM to produce protocol in same language as source.", artifact_name:"PromptTemplate", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"template", status:"draft"}}] AS row
CREATE (n:WorkflowStep{id: row.id}) SET n += row.properties;
UNWIND [{id:"BP-004-S04", properties:{actor:"EXT-03", step_order:4, created:date('2026-05-17'), name:"Submit Transcript + Prompt to LLM", description:"Worker assembles LLM request with transcript + prompt and submits to EXT-03. Specifies required sections: participants, topics, decisions, action items with assignees/deadlines.", artifact_name:"LLMRequest", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"api-payload", status:"draft"}}, {id:"BP-004-S05", properties:{actor:"System", step_order:5, created:date('2026-05-17'), name:"LLM Response Valid?", description:"Worker inspects LLM response. Success: 2xx with non-empty structured content. Failure: HTTP error, timeout, or malformed body.", artifact_name:"LLMResponse", stereotype:"decision", updated:date('2026-05-17'), artifact_kind:"api-payload", status:"draft"}}, {id:"BP-004-S06", properties:{actor:"System", step_order:6, created:date('2026-05-17'), name:"Parse LLM Response into Protocol Draft", description:"Worker parses output into structured Markdown with sections: Participants, Discussed Topics, Decisions Made, Action Items (assignee + deadline).", artifact_name:"ProtocolDraft", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"document", status:"draft"}}, {id:"BP-004-S07", properties:{actor:"System", assumption_note:"Section is present if heading exists with at least one non-empty content line. Partial-accept threshold TBD; MVP routes any missing section to failure.", step_order:7, created:date('2026-05-17'), name:"All Required Sections Present?", description:"Worker validates the draft contains all four required sections. Missing -> failure.", artifact_name:"ProtocolDraft", stereotype:"decision", updated:date('2026-05-17'), artifact_kind:"document", status:"draft"}}, {id:"BP-004-S08", properties:{actor:"System", step_order:8, created:date('2026-05-17'), name:"Persist Protocol as Markdown", description:"Worker writes validated draft to data store as Markdown linked to the meeting record.", artifact_name:"Protocol", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"document", status:"draft"}}, {id:"BP-004-S09", properties:{actor:"System", step_order:9, created:date('2026-05-17'), name:"Update Status to Protocol Ready", description:"Worker sets meeting status to protocol ready, making it available for BP-005.", artifact_name:"MeetingStatus", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"status", status:"draft"}}, {id:"BP-004-S10", properties:{actor:"System", assumption_note:"Retry (manual user-triggered or auto with back-off) TBD at SA phase. Errors logged for diagnostics.", step_order:10, created:date('2026-05-17'), name:"Update Status to Protocol Generation Failed", description:"Worker sets meeting status to protocol generation failed so the UI surfaces the error. User may retry manually.", artifact_name:"MeetingStatus", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"status", status:"draft"}}, {id:"BP-002-S07B", properties:{actor:"System (transcription worker)", assumption_note:"Name resolution method TBD: heuristic regex/lookup over the transcript, or a dedicated LLM pass with a name-resolution prompt. Mapping confidence threshold TBD. Unresolved labels stay as Speaker N.", step_order:8, created:date('2026-05-17'), name:"Resolve speaker names from dialogue context", description:"After segments are assembled, scan the transcript for self-introductions and addressed names (e.g., \"Я, Иван, ...\", \"Анна, что вы думаете?\"). When a name can be reliably associated with a speaker label, substitute the anonymous label (Speaker 1, Speaker 2, ...) with the resolved name across the transcript. Labels without a confident mapping remain as Speaker N.", artifact_name:"Transcript", stereotype:"automated", updated:date('2026-05-17'), artifact_kind:"entity", status:"draft"}}] AS row
CREATE (n:WorkflowStep{id: row.id}) SET n += row.properties;
UNWIND [{id:"FORM-MeetingCatalog", properties:{name:"Meeting catalog", description:"List view of all meetings owned by the current author. Each row is a Meeting with key metadata and status. Auto-refreshes for transient statuses.", updated:datetime('2026-05-18T07:04:29.613Z')}}, {id:"FORM-MeetingDetail", properties:{name:"Meeting detail", description:"Detail panel for a single meeting: shows Meeting + Recording metadata, current job error_reason on FAILED, and conditional action links (view transcript / review protocol / export PDF / delete).", updated:datetime('2026-05-18T07:04:29.613Z')}}, {id:"FORM-MeetingDeleteConfirm", properties:{name:"Confirm meeting deletion", description:"Confirmation dialog before destructive cascade-delete. Warns if a job is IN_PROGRESS.", updated:datetime('2026-05-18T07:04:29.613Z')}}, {id:"FORM-MeetingUpload", properties:{name:"Upload meeting video", description:"File picker + language hint + optional title. Submits to server, which streams in chunks to EXT-04 with progress reporting; inline validation errors per BRQ-001/002/003.", updated:datetime('2026-05-18T07:06:40.999Z')}}, {id:"FORM-TranscriptView", properties:{name:"Transcript view", description:"Read-only view of the verbatim transcript with speaker labels and timestamps. Header shows transcript metadata. Provides a one-click Download action.", updated:datetime('2026-05-18T07:07:50.001Z')}}, {id:"FORM-ProtocolEditor", properties:{name:"Protocol editor", description:"Markdown editor for the meeting protocol with side-by-side rendered preview. Header shows version + edit_count + last_edited_at. Save action increments version and edit_count per BRQ-014/015.", updated:datetime('2026-05-18T07:09:31.14Z')}}] AS row
CREATE (n:Form{id: row.id}) SET n += row.properties;
UNWIND [{id:"GPR-01", properties:{created:date('2026-05-17'), name:"Transcription Pipeline", description:"All processes from initial video upload through delivery of a verbatim, speaker-attributed transcript. Covers file handling, audio extraction, ASR/diarization, and transcript storage.", updated:date('2026-05-17'), status:"draft"}}, {id:"GPR-02", properties:{created:date('2026-05-17'), name:"Protocol Lifecycle", description:"All processes that transform a completed transcript into a structured meeting protocol: LLM-based generation, in-app review and editing, and PDF export.", updated:date('2026-05-17'), status:"draft"}}] AS row
CREATE (n:ProcessGroup{id: row.id}) SET n += row.properties;
UNWIND [{id:"BP-001", properties:{outputs:["File stored in object storage (EXT-04)", "Transcription job queued", "Upload confirmation shown to user"], owner:"STK-01", created:date('2026-05-17'), inputs:["Raw video file (300-500 MB, MP4/MKV/MOV or similar)"], name:"Upload Meeting Video", description:"User selects and uploads a meeting video file (300-500 MB) via the web interface. System validates the file, stores it in object storage, and enqueues an async transcription job.", trigger:"User initiates an upload action in the UI", updated:date('2026-05-17'), has_decomposition:true, status:"draft"}}, {id:"BP-002", properties:{outputs:["Verbatim speaker-attributed transcript with timestamps stored in the system", "Processing status updated to transcript ready"], owner:"STK-01", assumption_note:"Audio extraction step (demux from video container) is treated as an internal sub-step, not a separate business process, because it has no business decision point.", created:date('2026-05-17'), inputs:["Video/audio file from object storage (EXT-04)", "Speaker diarization request to ASR engine (EXT-02)"], name:"Transcribe Audio (ASR + Diarization)", description:"System retrieves the uploaded video from storage, extracts audio, submits it to the ASR/diarization engine (EXT-02), receives speaker-attributed transcript segments, assembles and persists the verbatim transcript.", trigger:"Transcription job is dequeued from the async processing queue", updated:date('2026-05-17'), has_decomposition:true, status:"draft"}}, {id:"BP-003", properties:{outputs:["Transcript file delivered to user (download)"], owner:"STK-01", assumption_note:"Simple retrieval/download operation. No complex branching at MVP scope.", created:date('2026-05-17'), inputs:["Persisted verbatim transcript (from BP-002)"], name:"Download / Retrieve Transcript", description:"User views and downloads the completed verbatim transcript from the system. The transcript is rendered in the UI and offered as a downloadable text/document file.", trigger:"User navigates to transcript view and requests download", updated:date('2026-05-17'), has_decomposition:false, status:"draft"}}, {id:"BP-004", properties:{outputs:["Meeting protocol stored as Markdown", "Processing status updated to protocol ready"], owner:"STK-01", assumption_note:"Protocol generation is triggered automatically after transcription completes; no manual user action is required to initiate it.", created:date('2026-05-17'), inputs:["Verbatim speaker-attributed transcript (from BP-002)", "Prompt template for structured protocol extraction"], name:"Generate Meeting Protocol", description:"System submits the verbatim transcript to the LLM protocol generator (EXT-03) with a structured extraction prompt. The LLM returns a meeting protocol. System persists the protocol as Markdown.", trigger:"Transcription job completes successfully (transcript is ready)", updated:date('2026-05-17'), has_decomposition:true, status:"draft"}}, {id:"BP-005", properties:{outputs:["Updated meeting protocol saved as Markdown"], owner:"STK-01", assumption_note:"Free-form Markdown edit; no structured field validation required at MVP scope.", created:date('2026-05-17'), inputs:["Generated meeting protocol in Markdown (from BP-004 or previous edit)"], name:"Review and Edit Protocol", description:"User opens the generated protocol in the in-app Markdown editor, reviews its content, makes corrections or additions, and saves the updated version.", trigger:"User opens the protocol view and chooses to edit", updated:date('2026-05-17'), has_decomposition:false, status:"draft"}}, {id:"BP-006", properties:{outputs:["PDF file delivered to user (download)"], owner:"STK-01", assumption_note:"PDF rendering uses a server-side export script (e.g. Pandoc or headless browser). Specific tool TBD with tech stack.", created:date('2026-05-17'), inputs:["Current meeting protocol Markdown (from BP-004 or BP-005)"], name:"Export Protocol to PDF", description:"User requests a PDF export of the meeting protocol. System renders the Markdown to PDF via an export script and delivers the file as a download.", trigger:"User clicks Export to PDF in the protocol view", updated:date('2026-05-17'), has_decomposition:false, status:"draft"}}] AS row
CREATE (n:BusinessProcess{id: row.id}) SET n += row.properties;
UNWIND [{id:"ent-001", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-common", name:"Meeting", description:"Root aggregate representing a single meeting being processed. Owns Recording, Transcript, Protocol references and tracks overall pipeline status.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}, {id:"ent-002", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-ingest", name:"Recording", description:"Metadata for the uploaded video file (filename, size, MIME, storage path). Physical file lives in EXT-04 Object Storage.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}, {id:"ent-003", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-transcription", name:"TranscriptionJob", description:"Async job tracking the ASR+diarization pipeline for a recording. Surfaces success/failure and error details.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}, {id:"ent-004", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-transcription", name:"Transcript", description:"Persisted verbatim speaker-attributed transcript from ASR+diarization. Segments stored inline at MVP scope.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}, {id:"ent-005", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-protocol", name:"ProtocolGenerationJob", description:"Async job tracking LLM-based protocol generation for a transcript. Auto-created when transcription completes.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}, {id:"ent-006", properties:{shared:false, created:datetime('2026-05-18T06:35:21.947Z'), module:"mod-protocol", name:"Protocol", description:"Persisted meeting protocol Markdown produced by LLM and refined by user. Sections: participants, topics, decisions, action items. Version-incremented on save.", updated:datetime('2026-05-18T06:35:21.947Z'), status:"draft"}}] AS row
CREATE (n:DomainEntity{id: row.id}) SET n += row.properties;
