Vite + React 19 + shadcn/ui + Tailwind + TanStack Query + Router + i18next RU/EN)", type:"tech", priority:"high", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, phase_review_be:"approved", status:"done"}}, {id:"TECH-014", properties:{agent:"nacl-tl-dev", last_reconciled:"2026-05-18", created:datetime('2026-05-18T08:41:16.385Z'), title:"Puppeteer PDF renderer (transient, never persisted)", priority:"medium", type:"tech", updated:datetime('2026-05-18T08:41:16.385Z'), wave:0, status:"done", phase_review_be:"approved"}}, {id:"TECH-015", properties:{agent:"nacl-tl-dev", created:datetime('2026-05-18T08:41:16.385Z'), ci_run_id:26045597888, title:"GitHub Actions CI (lint, typecheck, vitest, build)", priority:"medium", type:"tech", wave:0, phase_review_be:"approved", ci_run_url:"https://github.com/ITSalt/transcriber/actions/runs/26045597888", ci_verified:"2026-05-18", ci_run_conclusion:"success", last_reconciled:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-001-BE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-be", uc_ref:"UC-001", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", last_docs_sync:"2026-05-18", title:"Meeting catalog API", type:"uc-be", priority:"high", wave:1, phase_review_be:"approved", phase_be:"approved", last_reconciled:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-001-FE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-fe", uc_ref:"UC-001", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", phase_review_fe:"approved", last_docs_sync:"2026-05-18", title:"Meeting catalog page", type:"uc-fe", priority:"high", wave:2, phase_fe:"approved", last_reconciled:"2026-05-18", updated:datetime('2026-05-18T08:41:16.385Z'), status:"done"}}, {id:"UC-002-BE", properties:{phase_qa:"pass", agent:"nacl-tl-dev-be", uc_ref:"UC-002", created:datetime('2026-05-18T08:41:16.385Z'), phase_sync:"pass", title:"Meeting detail API", type:"uc-be", priority:"high", wave: