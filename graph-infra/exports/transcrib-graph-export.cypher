5-A07", properties:{name:"started_at", description:"Timestamp when the worker picked up the job", type:"DateTime", required:false}}, {id:"OBJ-005-A08", properties:{name:"completed_at", description:"Timestamp when the job reached a terminal state", type:"DateTime", required:false}}, {id:"OBJ-006-A01", properties:{name:"id", description:"Unique protocol identifier", type:"UUID", required:true}}, {id:"OBJ-006-A02", properties:{name:"meeting_id", description:"Foreign key to owning Meeting (OBJ-001)", type:"UUID", required:true}}, {id:"OBJ-006-A03", properties:{name:"markdown_content", description:"Full protocol text in Markdown; the authoritative editable representation", type:"Text", required:true}}, {id:"OBJ-006-A04", properties:{name:"generated_at", description:"Timestamp when the protocol was first produced by the LLM pipeline", type:"DateTime", required:true}}, {id:"OBJ-006-A05", properties:{name:"last_edited_at", description:"Timestamp of the most recent manual save in BP-005; null if never edited", type:"DateTime", required:false}}] AS row
