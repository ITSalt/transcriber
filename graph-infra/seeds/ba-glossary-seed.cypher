// -----------------------------------------------------------------------------
// GLO-014 — Transcription Pipeline
// -----------------------------------------------------------------------------
MERGE (glo014:GlossaryTerm {id: 'GLO-014'})
SET glo014.name            = 'Transcription Pipeline',
    glo014.definition      = 'The end-to-end automated sequence of steps that transforms an uploaded video recording into a verbatim speaker-attributed transcript. Encompasses audio extraction, ASR, and speaker diarization.',
    glo014.aliases         = ['Пайплайн транскрибации', 'Transcription Flow'],
    glo014.context         = 'Corresponds to BP-002 (Transcribe Audio) and its constituent workflow steps.',
    glo014.status          = 'draft',
    glo014.created         = date('2026-05-17'),
    glo014.updated         = date('2026-05-17');

MERGE (glo014:GlossaryTerm {id: 'GLO-014'})
MERGE (bp002:BusinessProcess {id: 'BP-002'})
MERGE (glo014)-[:DEFINES_TERM]->(bp002);

// -----------------------------------------------------------------------------
// GLO-015 — Protocol Lifecycle
// -----------------------------------------------------------------------------
MERGE (glo015:GlossaryTerm {id: 'GLO-015'})
SET glo015.name            = 'Protocol Lifecycle',
    glo015.definition      = 'The ordered sequence of states a Meeting Protocol passes through from generation to final export: generated → edited (zero or more times) → exported. Tracks how the document evolves after LLM creation.',
    glo015.aliases         = ['Жизненный цикл протокола'],
    glo015.context         = 'Spans BP-004 (generation), BP-005 (editing), BP-006 (export); states tracked via OBJ-006 and Meeting status OBJ-001.',
    glo015.status          = 'draft',
    glo015.created         = date('2026-05-17'),
    glo015.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-016 — ASR (Automatic Speech Recognition)
// -----------------------------------------------------------------------------
MERGE (glo016:GlossaryTerm {id: 'GLO-016'})
SET glo016.name            = 'ASR',
    glo016.definition      = 'Automatic Speech Recognition — the technology that converts audio speech into written text. In Transcrib, ASR is performed by an external engine (EXT-01) that also handles speaker diarization.',
    glo016.aliases         = ['Automatic Speech Recognition', 'Распознавание речи', 'Speech-to-Text', 'STT'],
    glo016.context         = 'Invoked inside BP-002 (Transcription); vendor/model is TBD.',
    glo016.status          = 'draft',
    glo016.created         = date('2026-05-17'),
    glo016.updated         = date('2026-05-17');

MERGE (glo016:GlossaryTerm {id: 'GLO-016'})
MERGE (ext01:ExternalEntity {id: 'EXT-01'})
MERGE (glo016)-[:DEFINES_TERM]->(ext01);

// -----------------------------------------------------------------------------
// GLO-017 — LLM (Large Language Model)
// -----------------------------------------------------------------------------
MERGE (glo017:GlossaryTerm {id: 'GLO-017'})
SET glo017.name            = 'LLM',
    glo017.definition      = 'Large Language Model — an AI model used to summarize and structure the verbatim transcript into a formatted meeting protocol. The LLM receives a prompt containing the transcript and a template, and returns structured Markdown.',
    glo017.aliases         = ['Large Language Model', 'Большая языковая модель', 'Language Model'],
    glo017.context         = 'Invoked inside BP-004 (Protocol Generation) via EXT-02; specific service is TBD.',
    glo017.status          = 'draft',
    glo017.created         = date('2026-05-17'),
    glo017.updated         = date('2026-05-17');

MERGE (glo017:GlossaryTerm {id: 'GLO-017'})
MERGE (ext02:ExternalEntity {id: 'EXT-02'})
MERGE (glo017)-[:DEFINES_TERM]->(ext02);

// -----------------------------------------------------------------------------
// GLO-018 — Async Job
// -----------------------------------------------------------------------------
MERGE (glo018:GlossaryTerm {id: 'GLO-018'})
SET glo018.name            = 'Async Job',
    glo018.definition      = 'An asynchronous background task that performs a long-running operation (transcription or protocol generation) outside the synchronous request-response cycle. The user polls or receives a notification when the job completes.',
    glo018.aliases         = ['Асинхронная задача', 'Background Job'],
    glo018.context         = 'Materialized as OBJ-003 (TranscriptionJob) and OBJ-005 (ProtocolGenerationJob).',
    glo018.status          = 'draft',
    glo018.created         = date('2026-05-17'),
    glo018.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-019 — TranscriptionJob
// -----------------------------------------------------------------------------
MERGE (glo019:GlossaryTerm {id: 'GLO-019'})
SET glo019.name            = 'TranscriptionJob',
    glo019.definition      = 'The specific async job record that tracks ASR and diarization pipeline execution for a single recording. Transitions through queued → in_progress → completed | failed, and is the primary means of surfacing transcription progress and errors to the system.',
    glo019.aliases         = ['Задача транскрибации'],
    glo019.context         = 'Created in BP-001; executed in BP-002. Corresponds to OBJ-003.',
    glo019.status          = 'draft',
    glo019.created         = date('2026-05-17'),
    glo019.updated         = date('2026-05-17');

MERGE (glo019:GlossaryTerm {id: 'GLO-019'})
MERGE (obj003:BusinessEntity {id: 'OBJ-003'})
MERGE (glo019)-[:DEFINES_TERM]->(obj003);

// -----------------------------------------------------------------------------
// GLO-020 — ProtocolGenerationJob
// -----------------------------------------------------------------------------
MERGE (glo020:GlossaryTerm {id: 'GLO-020'})
SET glo020.name            = 'ProtocolGenerationJob',
    glo020.definition      = 'The specific async job record that tracks LLM-based protocol generation for a single transcript. Created automatically when the TranscriptionJob completes; tracks prompt template version, timing, and failure details.',
    glo020.aliases         = ['Задача генерации протокола'],
    glo020.context         = 'Triggered at end of BP-002; executed in BP-004. Corresponds to OBJ-005.',
    glo020.status          = 'draft',
    glo020.created         = date('2026-05-17'),
    glo020.updated         = date('2026-05-17');

MERGE (glo020:GlossaryTerm {id: 'GLO-020'})
MERGE (obj005:BusinessEntity {id: 'OBJ-005'})
MERGE (glo020)-[:DEFINES_TERM]->(obj005);

// -----------------------------------------------------------------------------
// GLO-021 — Object Storage
// -----------------------------------------------------------------------------
MERGE (glo021:GlossaryTerm {id: 'GLO-021'})
SET glo021.name            = 'Object Storage',
    glo021.definition      = 'A remote binary storage service used to persist large video files uploaded by the user. The system stores the file in object storage and records only the storage path reference in the Recording entity.',
    glo021.aliases         = ['Объектное хранилище', 'Blob Storage', 'File Storage'],
    glo021.context         = 'Corresponds to EXT-04; used in BP-001 (Upload) and BP-002 (Transcription); specific service is TBD.',
    glo021.status          = 'draft',
    glo021.created         = date('2026-05-17'),
    glo021.updated         = date('2026-05-17');

MERGE (glo021:GlossaryTerm {id: 'GLO-021'})
MERGE (ext04:ExternalEntity {id: 'EXT-04'})
MERGE (glo021)-[:DEFINES_TERM]->(ext04);

// -----------------------------------------------------------------------------
// GLO-022 — Prompt Template
// -----------------------------------------------------------------------------
MERGE (glo022:GlossaryTerm {id: 'GLO-022'})
SET glo022.name            = 'Prompt Template',
    glo022.definition      = 'A versioned template that defines the structure and instructions given to the LLM when generating a meeting protocol from a transcript. The template controls which sections (participants, topics, decisions, action items) the LLM must produce and in what format.',
    glo022.aliases         = ['Шаблон промпта', 'LLM Prompt'],
    glo022.context         = 'Used in BP-004 (Protocol Generation); version is recorded in OBJ-005 (ProtocolGenerationJob) for audit.',
    glo022.assumption_note = 'Template format and versioning mechanism are TBD at MVP; the term is recorded to ensure traceability of generation reproducibility.',
    glo022.status          = 'draft',
    glo022.created         = date('2026-05-17'),
    glo022.updated         = date('2026-05-17');

