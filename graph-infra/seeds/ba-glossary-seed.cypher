// GLOSSARY TERMS — Operational Concepts
// =============================================================================

// -----------------------------------------------------------------------------
// GLO-023 — Markdown
// -----------------------------------------------------------------------------
MERGE (glo023:GlossaryTerm {id: 'GLO-023'})
SET glo023.name            = 'Markdown',
    glo023.definition      = 'A lightweight text markup language used as the internal storage format for meeting protocols. The user edits the protocol as Markdown in the built-in editor; Markdown is also the source format for PDF export.',
    glo023.aliases         = ['Маркдаун'],
    glo023.context         = 'Stored in OBJ-006.markdown_content; edited in BP-005; exported in BP-006.',
    glo023.status          = 'draft',
    glo023.created         = date('2026-05-17'),
    glo023.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-024 — PDF Export
// -----------------------------------------------------------------------------
MERGE (glo024:GlossaryTerm {id: 'GLO-024'})
SET glo024.name            = 'PDF Export',
    glo024.definition      = 'The on-demand conversion of a Markdown protocol document to a PDF file delivered to the user as a browser download. The PDF is a transient artifact — it is not persisted in the system after delivery.',
    glo024.aliases         = ['Экспорт в PDF', 'Export to PDF'],
    glo024.context         = 'Performed in BP-006 (Export Protocol to PDF); triggered by the Author.',
    glo024.status          = 'draft',
    glo024.created         = date('2026-05-17'),
    glo024.updated         = date('2026-05-17');

MERGE (glo024:GlossaryTerm {id: 'GLO-024'})
MERGE (bp006:BusinessProcess {id: 'BP-006'})
MERGE (glo024)-[:DEFINES_TERM]->(bp006);

// -----------------------------------------------------------------------------
// GLO-025 — Upload
// -----------------------------------------------------------------------------
MERGE (glo025:GlossaryTerm {id: 'GLO-025'})
SET glo025.name            = 'Upload',
    glo025.definition      = 'The user action of submitting a video file to the system via the web interface. Upload initiates the meeting record creation and queues the transcription pipeline. Files up to 300–500 MB must be supported.',
    glo025.aliases         = ['Загрузка', 'File Upload'],
    glo025.context         = 'The first user action; corresponds to BP-001 (Upload Meeting Video).',
    glo025.status          = 'draft',
    glo025.created         = date('2026-05-17'),
    glo025.updated         = date('2026-05-17');

MERGE (glo025:GlossaryTerm {id: 'GLO-025'})
MERGE (bp001:BusinessProcess {id: 'BP-001'})
MERGE (glo025)-[:DEFINES_TERM]->(bp001);

// -----------------------------------------------------------------------------
// GLO-026 — Language Hint
// -----------------------------------------------------------------------------
MERGE (glo026:GlossaryTerm {id: 'GLO-026'})
SET glo026.name            = 'Language Hint',
    glo026.definition      = 'An optional user-supplied indication of the primary spoken language in the recording (e.g., Russian, English, or auto-detect). The ASR engine uses this hint to improve transcription accuracy.',
    glo026.aliases         = ['Подсказка языка', 'Source Language', 'Language Setting'],
    glo026.context         = 'Stored as Meeting.language (OBJ-001-A03); supplied during BP-001 (Upload); passed to the ASR engine in BP-002.',
    glo026.assumption_note = 'The set of supported languages and whether auto-detection is accurate are TBD pending ASR vendor selection.',
    glo026.status          = 'draft',
    glo026.created         = date('2026-05-17'),
    glo026.updated         = date('2026-05-17');

MERGE (glo026:GlossaryTerm {id: 'GLO-026'})
