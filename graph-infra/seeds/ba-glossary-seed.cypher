// -----------------------------------------------------------------------------
// GLO-001 — Meeting
// -----------------------------------------------------------------------------
MERGE (glo001:GlossaryTerm {id: 'GLO-001'})
SET glo001.name            = 'Meeting',
    glo001.definition      = 'A single business meeting whose recording is uploaded into the system for processing. The root object that owns the resulting recording, transcript, and protocol throughout its lifecycle.',
    glo001.aliases         = ['Встреча', 'Session'],
    glo001.context         = 'Used throughout all processes (BP-001..BP-006); the top-level aggregate (OBJ-001).',
    glo001.status          = 'draft',
    glo001.created         = date('2026-05-17'),
    glo001.updated         = date('2026-05-17');

MERGE (glo001:GlossaryTerm {id: 'GLO-001'})
MERGE (obj001:BusinessEntity {id: 'OBJ-001'})
MERGE (glo001)-[:DEFINES_TERM]->(obj001);

// -----------------------------------------------------------------------------
// GLO-002 — Recording
// -----------------------------------------------------------------------------
MERGE (glo002:GlossaryTerm {id: 'GLO-002'})
SET glo002.name            = 'Recording',
    glo002.definition      = 'The video file uploaded by the Author that captures the meeting. The physical file is stored in object storage; the system tracks its metadata (filename, size, duration, storage path) as the Recording entity.',
    glo002.aliases         = ['Видеозапись', 'Запись', 'Video File'],
    glo002.context         = 'Created in BP-001 (Upload); consumed in BP-002 (Transcription). Corresponds to OBJ-002.',
    glo002.status          = 'draft',
    glo002.created         = date('2026-05-17'),
    glo002.updated         = date('2026-05-17');

MERGE (glo002:GlossaryTerm {id: 'GLO-002'})
MERGE (obj002:BusinessEntity {id: 'OBJ-002'})
MERGE (glo002)-[:DEFINES_TERM]->(obj002);

// -----------------------------------------------------------------------------
// GLO-003 — Transcript
// -----------------------------------------------------------------------------
MERGE (glo003:GlossaryTerm {id: 'GLO-003'})
SET glo003.name            = 'Transcript',
    glo003.definition      = 'The verbatim, speaker-attributed text output of the transcription pipeline. Contains the full spoken content of the meeting with speaker labels and timestamps per segment. Sometimes called a "verbatim transcript" to distinguish it from a summarized protocol.',
    glo003.aliases         = ['Транскрипт', 'Пословная транскрибация', 'Verbatim Transcript'],
    glo003.context         = 'Produced by BP-002 (Transcription); consumed by BP-003 (Retrieve) and BP-004 (Protocol Generation). Corresponds to OBJ-004.',
    glo003.status          = 'draft',
    glo003.created         = date('2026-05-17'),
    glo003.updated         = date('2026-05-17');

MERGE (glo003:GlossaryTerm {id: 'GLO-003'})
MERGE (obj004:BusinessEntity {id: 'OBJ-004'})
MERGE (glo003)-[:DEFINES_TERM]->(obj004);

// -----------------------------------------------------------------------------
// GLO-004 — Speaker Diarization
// -----------------------------------------------------------------------------
MERGE (glo004:GlossaryTerm {id: 'GLO-004'})
SET glo004.name            = 'Speaker Diarization',
    glo004.definition      = 'The automated process of partitioning an audio stream into segments and labeling each segment with a speaker identity (e.g., Speaker 1, Speaker 2). Diarization answers the question "who spoke when" and is a required step of the transcription pipeline.',
    glo004.aliases         = ['Диаризация спикеров', 'Diarization'],
    glo004.context         = 'Performed inside BP-002 (Transcription) by the ASR/Diarization Engine (EXT-01). Output feeds into speaker-attributed transcript segments.',
    glo004.status          = 'draft',
    glo004.created         = date('2026-05-17'),
    glo004.updated         = date('2026-05-17');

MERGE (glo004:GlossaryTerm {id: 'GLO-004'})
MERGE (ext01:ExternalEntity {id: 'EXT-01'})
MERGE (glo004)-[:DEFINES_TERM]->(ext01);

// -----------------------------------------------------------------------------
// GLO-005 — Speaker Segment
// -----------------------------------------------------------------------------
MERGE (glo005:GlossaryTerm {id: 'GLO-005'})
SET glo005.name            = 'Speaker Segment',
    glo005.definition      = 'A contiguous block of speech attributed to a single speaker, with a start timestamp, end timestamp, speaker label, and verbatim text. Multiple segments together form the full Transcript.',
    glo005.aliases         = ['Сегмент транскрипта', 'Transcript Segment'],
    glo005.context         = 'Produced by the diarization step inside BP-002; stored as structured content within OBJ-004 (Transcript) at MVP scope.',
    glo005.status          = 'draft',
    glo005.created         = date('2026-05-17'),
    glo005.updated         = date('2026-05-17');

// No direct DEFINES_TERM pointer — segment is embedded in OBJ-004, not a top-level graph node at MVP.

// -----------------------------------------------------------------------------
// GLO-006 — Meeting Protocol
// -----------------------------------------------------------------------------
MERGE (glo006:GlossaryTerm {id: 'GLO-006'})
SET glo006.name            = 'Meeting Protocol',
    glo006.definition      = 'A structured summary document produced from the transcript by the LLM generation pipeline. Contains sections for meeting participants, discussion topics, decisions made, and action items with assignees and deadlines. Stored in Markdown and exportable to PDF.',
    glo006.aliases         = ['Протокол встречи', 'Protocol', 'Minutes'],
    glo006.context         = 'Produced by BP-004; edited in BP-005; exported in BP-006. Corresponds to OBJ-006.',
    glo006.status          = 'draft',
    glo006.created         = date('2026-05-17'),
    glo006.updated         = date('2026-05-17');

MERGE (glo006:GlossaryTerm {id: 'GLO-006'})
MERGE (obj006:BusinessEntity {id: 'OBJ-006'})
MERGE (glo006)-[:DEFINES_TERM]->(obj006);

// GLO-007 is "Protocol" — canonical synonym of GLO-006 (Meeting Protocol)
MERGE (glo007:GlossaryTerm {id: 'GLO-007'})
SET glo007.name            = 'Protocol',
    glo007.definition      = 'Short-form alias for Meeting Protocol (GLO-006). Used interchangeably in the codebase and UI labels.',
    glo007.aliases         = ['Протокол'],
    glo007.context         = 'Appears in entity names (OBJ-006), process names (BP-004, BP-005, BP-006), and UI labels.',
    glo007.status          = 'draft',
    glo007.created         = date('2026-05-17'),
    glo007.updated         = date('2026-05-17');

MERGE (glo007:GlossaryTerm {id: 'GLO-007'})
MERGE (glo006:GlossaryTerm {id: 'GLO-006'})
MERGE (glo007)-[:SYNONYM_OF]->(glo006);

// -----------------------------------------------------------------------------
// GLO-008 — Action Item
// -----------------------------------------------------------------------------
MERGE (glo008:GlossaryTerm {id: 'GLO-008'})
SET glo008.name            = 'Action Item',
    glo008.definition      = 'A task agreed upon during the meeting, assigned to a named person with a deadline. Action items are extracted by the LLM from the transcript and appear as a dedicated section of the protocol.',
    glo008.aliases         = ['Поручение', 'Задача', 'Task'],
    glo008.context         = 'Captured as a section within OBJ-006 (Protocol); extracted during BP-004 (Protocol Generation).',
    glo008.status          = 'draft',
    glo008.created         = date('2026-05-17'),
    glo008.updated         = date('2026-05-17');

// No separate graph node — embedded in Protocol document.

// -----------------------------------------------------------------------------
// GLO-009 — Decision
// -----------------------------------------------------------------------------
MERGE (glo009:GlossaryTerm {id: 'GLO-009'})
SET glo009.name            = 'Decision',
    glo009.definition      = 'A conclusion or resolution reached during the meeting that is explicitly recorded in the protocol. Decisions are distinct from action items in that they represent outcomes rather than future tasks.',
    glo009.aliases         = ['Решение'],
    glo009.context         = 'Captured as a section within OBJ-006 (Protocol); extracted during BP-004 (Protocol Generation).',
    glo009.status          = 'draft',
    glo009.created         = date('2026-05-17'),
    glo009.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-010 — Discussion Topic
// -----------------------------------------------------------------------------
MERGE (glo010:GlossaryTerm {id: 'GLO-010'})
SET glo010.name            = 'Discussion Topic',
    glo010.definition      = 'A distinct agenda point or subject discussed during the meeting. The LLM groups related transcript content under topics, which become named sections within the protocol.',
    glo010.aliases         = ['Тема обсуждения', 'Вопрос', 'Agenda Item'],
    glo010.context         = 'Captured as a section within OBJ-006 (Protocol); extracted during BP-004 (Protocol Generation).',
    glo010.status          = 'draft',
    glo010.created         = date('2026-05-17'),
    glo010.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-011 — Participant
// -----------------------------------------------------------------------------
MERGE (glo011:GlossaryTerm {id: 'GLO-011'})
SET glo011.name            = 'Participant',
    glo011.definition      = 'A person who took part in the meeting. Participants are identified from the transcript by the diarization engine (as speaker labels) and optionally mapped to real names. The participant list appears as a dedicated section of the protocol.',
    glo011.aliases         = ['Участник', 'Attendee', 'Speaker'],
    glo011.context         = 'Derived from speaker segments in OBJ-004 (Transcript); surfaced in OBJ-006 (Protocol).',
    glo011.status          = 'draft',
    glo011.created         = date('2026-05-17'),
    glo011.updated         = date('2026-05-17');

// -----------------------------------------------------------------------------
// GLO-012 — Author (Role)
// -----------------------------------------------------------------------------
MERGE (glo012:GlossaryTerm {id: 'GLO-012'})
SET glo012.name            = 'Author',
    glo012.definition      = 'The business role representing the person who uploaded the meeting recording and owns all derived artifacts (transcript and protocol). The primary — and at MVP the only — active human role in the system.',
    glo012.aliases         = ['Автор', 'Uploader'],
    glo012.context         = 'Defined as ROL-01; performs BP-001, BP-003, BP-005, BP-006.',
    glo012.status          = 'draft',
    glo012.created         = date('2026-05-17'),
    glo012.updated         = date('2026-05-17');

MERGE (glo012:GlossaryTerm {id: 'GLO-012'})
MERGE (rol01:BusinessRole {id: 'ROL-01'})
MERGE (glo012)-[:DEFINES_TERM]->(rol01);

// -----------------------------------------------------------------------------
// GLO-013 — Reviewer (Role)
// -----------------------------------------------------------------------------
MERGE (glo013:GlossaryTerm {id: 'GLO-013'})
SET glo013.name            = 'Reviewer',
    glo013.definition      = 'A business role representing a meeting participant who reads and validates the generated protocol. At MVP there is no technical distinction from Author; this role is modeled as an assumption for future access-control design.',
    glo013.aliases         = ['Проверяющий', 'Читатель'],
    glo013.context         = 'Defined as ROL-02; assumption — no distinct system behavior at MVP.',
    glo013.assumption_note = 'No authentication or sharing mechanism exists at MVP. This role is forward-looking only.',
    glo013.status          = 'draft',
    glo013.created         = date('2026-05-17'),
    glo013.updated         = date('2026-05-17');

MERGE (glo013:GlossaryTerm {id: 'GLO-013'})
MERGE (rol02:BusinessRole {id: 'ROL-02'})
MERGE (glo013)-[:DEFINES_TERM]->(rol02);

