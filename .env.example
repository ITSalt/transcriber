# PostgreSQL
# Docker Compose default: postgres://transcrib:transcrib@localhost:5432/transcrib
DATABASE_URL=postgres://transcrib:transcrib@localhost:5432/transcrib

# Redis
# Docker Compose default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# S3 / MinIO (dev) or Cloud.ru (prod)
# Docker Compose default: MinIO on localhost:9000
# Prod example: S3_ENDPOINT=https://s3.cloud.ru  S3_REGION=ru-central-1
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=transcrib
S3_KEY=minioadmin
S3_SECRET=minioadmin
# Region: default us-east-1 (MinIO dev); set to ru-central-1 for Cloud.ru prod
S3_REGION=us-east-1
# Force path-style URLs — required for MinIO; also works with Cloud.ru
S3_FORCE_PATH_STYLE=true

# Puppeteer / Chrome (prod only)
# Set to system Chrome binary path in prod. Leave unset in dev (bundled Chrome used).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Deepgram ASR
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LLM (kie.ai)
KIE_API_KEY=your_kie_api_key_here
