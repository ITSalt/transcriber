{
  "name": "@transcrib/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@transcrib/shared": "workspace:*",
    "@tus/s3-store": "^2.0.4",
    "@tus/server": "^2.4.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "bullmq": "^5.76.10",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "puppeteer": "^25.0.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/pg": "^8.20.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
